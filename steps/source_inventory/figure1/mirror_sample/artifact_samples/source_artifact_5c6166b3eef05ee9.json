    "",
    "## Data cleaning",
    "",
    "Fro the original data we drop all the observations with missing values for declared taxes (`decl_taxes` variable), missing turnout or average salary per month. We also excluded observations for May where there were a lot of missing values for declared taxes.",
    "",
    "```{r dist, echo=F, message=FALSE, warning=FALSE}",
    "df<-mydata%>%",
    "  filter(month!='May')%>%",
    "  drop_na(turnout, avg_salary, decl_taxes)",
    "",
    "# We also create an aggregated dataset with averages for months before intervention (June-July-August),",
    "# and averages for months after intervention (October-November-December)",
    "",
    "df<-df%>%mutate(net_paid= paid_tax-returned_tax)  ",
    " ",
    "long_ba <- df %>%",
    "  # filter(month!='September')%>%",
    "  mutate(after = ifelse(as.numeric(month) > 4, 'after', 'before')) %>%",
    "  group_by(id, approach,treatment, years, after, feedback, response) %>%",
    "  summarise(",
    "    mean_net_paid=mean(net_paid, na.rm=T),",
    "    mean_salary = mean((avg_salary), na.rm = T),",
    "    mean_decl_taxes = mean(decl_taxes, na.rm = T),",
    "    mean_turnout = mean(turnout, na.rm = T),",
    "    mean_employees = mean(employees, na.rm = T),",
    "    mean_returned_tax = mean(returned_tax, na.rm = T),",
    "    mean_paid_tax=mean(paid_tax, na.rm=T)",
    "  )",
    "",
    "",
    "ba_data <- long_ba %>%",
    "  pivot_wider(",
    "    names_from = after,",
    "    values_from = c(",
    "      mean_net_paid,",
    "      mean_salary,",
    "      mean_decl_taxes,",
    "      mean_turnout,",
    "      mean_employees,",
    "      mean_returned_tax,",
    "      mean_paid_tax",
    "    )",
    "  ) %>%",
    "  mutate(",
    "    diff_net_paid=mean_net_paid_after-mean_net_paid_before,",
    "    diff_salary = mean_salary_after - mean_salary_before,",
    "    diff_decl_taxes = mean_decl_taxes_after - mean_decl_taxes_before,"
