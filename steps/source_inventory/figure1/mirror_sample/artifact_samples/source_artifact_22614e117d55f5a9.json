  "line_preview": [
    "myrepo = \"http://cran.us.r-project.org\"",
    "if (!require(\"tidyverse\")) install.packages(\"tidyverse\", repos = myrepo)",
    "if (!require(\"lubridate\")) install.packages(\"lubridate\", repos = myrepo)",
    "if (!require(\"scales\")) install.packages(\"scales\", repos = myrepo)",
    "#library(\"tidyverse\", \"lubridate\", \"scales\")",
    "",
    "segments <- c(\"Everyone\",\"Black / African American\",\"Latinx / Hispanic\",\"Conservative\",\"Religious\",\"Parent\")",
    "statacolors <- c(\"#000000\", \"#0000ff\", \"#008000\", \"#ff0000\", \"#ff7f00\", \"#800080\")",
    "# Of course it must be alphabetical for some reason",
    "#segcolors <- c(\"blue\", \"red\", \"black\", \"green\", \"violet\", \"orange\")",
    "#okabe <- c(\"#E69F00\", \"#56B4E9\", \"#009E73\", \"#F0E442\", \"#0072B2\", \"#D55E00\", \"#CC79A7\")",
    "",
    "#library(\"colorspace\")",
    "#segcolors <- qualitative_hcl(6, palette = \"Dark 2\")",
    "#palette.colors(n = 6, palette = \"Okabe-Ito\")",
    "",
    "data <- read.csv(\"temp/data_sampleR.csv\")",
    "data <- data %>%",
    "    mutate(screen_clock = dmy_hms(screen_clock)) %>%",
    "    mutate(survey_clock = dmy_hms(survey_clock)) %>%",
    "    mutate(finished = replace(finished, is.na(finished), 0))",
    "data$finished <- factor(data$finished)",
    "",
    "plot_cum <- ggplot(data,aes(x=screen_clock, group=finished)) +",
    "            geom_line(aes(y = screen_cum, linetype=finished, color=segments[1])) +",
    "            geom_line(data=subset(data,finished==1), aes(x=survey_clock, y = survey_cum, linetype=finished, color=segments[1])) +",
    "            geom_line(data=subset(data,finished==1&d_b==1), aes(x=survey_clock, y = survey_cum_b, linetype=finished, color=segments[2])) +",
    "            geom_line(data=subset(data,finished==1&d_l==1), aes(x=survey_clock, y = survey_cum_l, linetype=finished, color=segments[3])) +",
    "            geom_line(data=subset(data,finished==1&d_c==1), aes(x=survey_clock, y = survey_cum_c, linetype=finished, color=segments[4])) +",
    "            geom_line(data=subset(data,finished==1&d_r==1), aes(x=survey_clock, y = survey_cum_r, linetype=finished, color=segments[5])) +",
    "            geom_line(data=subset(data,finished==1&d_p==1), aes(x=survey_clock, y = survey_cum_p, linetype=finished, color=segments[6])) +",
    "            geom_line(data=subset(data,d_b==1), aes(y = screen_cum_b, color=segments[2], group=segments[2])) +",
    "            geom_line(data=subset(data,d_l==1), aes(y = screen_cum_l, color=segments[3], group=segments[3])) +",
    "            geom_line(data=subset(data,d_c==1), aes(y = screen_cum_c, color=segments[4], group=segments[4])) +",
    "            geom_line(data=subset(data,d_r==1), aes(y = screen_cum_r, color=segments[5], group=segments[5])) +",
    "            geom_line(data=subset(data,d_p==1), aes(y = screen_cum_p, color=segments[6], group=segments[6])) +",
    "            scale_y_continuous(expand = c(0, 0), limits=c(0, 8500)) +",
    "            scale_x_datetime(labels = date_format(\"%d\"), date_breaks = \"1 day\", expand = c(0, 0), limits=c(ymd_hms(\"2021-04-07 00:00:00 UTC\"),ymd_hms(\"2021-04-30 23:59:59 UTC\"))) +",
    "            labs(title=\"Responses overall and by segment\",",
    "                 x=\"Day of April 2021\", y=\"Cumulative responses\",",
    "                 color=\"Segment\", linetype=\"Completed\") +",
    "            scale_color_manual(breaks=segments, values=statacolors) +",
    "            scale_linetype_manual(values=c(\"solid\",\"dashed\"), labels=c(\"Screening survey\",\"Experimental survey\")) +",
    "            theme_bw()+theme(plot.background = element_rect(fill = \"gray95\"))+theme(legend.background = element_rect(colour = \"black\", fill = \"white\"))",
    "",
    "ggsave(plot_cum, filename = \"output/figure_recruiting.pdf\", height=4, width=8)",
