    "//// RCT Survey: Summary statistics",
    "//// Lucas Reddinger <jlr@lucasreddinger.com>, David Levine, Gary Charness",
    "//// 2021 May 17; Updated 4 February 2025",
    "",
    "local this_file \"summary_statistics\"",
    "",
    "local path_logs \"logs/\"",
    "local path_output \"output/\"",
    "local path_temp \"temp/\"",
    "",
    "local data_dta \"data\"",
    "",
    "capture mkdir `path_logs'",
    "capture mkdir `path_output'",
    "capture mkdir `path_temp'",
    "",
    "capture log close",
    "log using \"`path_logs'`this_file'.txt\", text replace",
    "",
    "**** End boilerplate",
    "",
    "",
    "",
    "***********************",
    "***********************",
    "**** SUMMARY STATISTICS",
    "***********************",
    "***********************",
    "",
    "*************",
    "**** SAMPLE A",
    "*************",
    "use \"`path_temp'`data_dta'_sampleA.dta\", clear",
    "",
    "**** Define segment and control variable lists",
    "local segmentvars \"d_b d_l d_c d_r d_p\"",
    "",
    "**** OVERALL ***************************************************************",
    "sum vax_likely",
    "tab vax_likely",
    "",
    "foreach x of varlist `segmentvars' {",
    "\tdi \"\"",
    "\tdi \"**** SEGMENT `x' ***********************************************************\"",
    "\tsum vax_likely if `x'==1",
    "\ttab vax_likely if `x'==1",
    "\tttest vax_likely if `x'==1|num_segs==0, by(`x')",
    "}",
    "",
    "**** MEMBER OF AT LEAST ONE SEGMENT ****************************************",
    "sum vax_likely if any_segs",
    "tab vax_likely if any_segs",
    "ttest vax_likely, by(any_segs)",
    "",
    "**** MEMBER OF NO SEGMENT **************************************************",
    "sum vax_likely if zero_segs",
    "tab vax_likely if zero_segs",
    "",
    "*************",
    "**** SAMPLE C",
    "*************",
    "use \"`path_temp'`data_dta'_sampleC.dta\", clear",
    "",
    "**** Define segment and control variable lists",
    "local segmentvars \"d_b d_l d_c d_r\"",
    "",
    "**** OVERALL ***************************************************************",
    "sum vax_child",
    "tab vax_child",
    "",
    "foreach x of varlist `segmentvars' {",
    "\tdi \"\"",
    "\tdi \"**** SEGMENT `x' ***********************************************************\"",
    "\tsum vax_child if `x'==1",
    "\ttab vax_child if `x'==1",
    "\tttest vax_child if `x'==1|num_segs==0, by(`x')",
    "}",
    "",
    "**** MEMBER OF AT LEAST ONE SEGMENT ****************************************",
    "sum vax_child if any_segs"
  ],
