  "line_preview": [
    "/***************************************************************************",
    "",
    "\tDESCRIPTION: \tThis do file calculates baseline and long-term effects ",
    "\t\t\t\t\tusing various tax indices and compares different ",
    "\t\t\t\t\ttreatment groups. Additionally, it generates LaTeX ",
    "\t\t\t\t\ttables summarizing the results for baseline and ",
    "\t\t\t\t\trobustness analyses, including control means, ",
    "\t\t\t\t\tobservations, and statistical significance.",
    "\t",
    "\tINPUTS:\t\t\t- surveysDataset.dta",
    "\t",
    "\tOUTPUTS:\t\t- table_3.tex",
    "\t\t\t\t\t- table_a7.tex",
    "\t\t\t\t\t",
    "***************************************************************************/",
    " ",
    "********************************************************************************",
    "* 0. PREAMBLE",
    "********************************************************************************",
    "",
    "clear",
    "clear matrix",
    "clear mata",
    "set more off",
    "estimates clear",
    "",
    "********************************************************************************",
    "* 1. INFORMAL TAXATION RESULTS",
    "********************************************************************************",
    "use \"${data}/surveysDataset.dta\", clear",
    "",
    "drop if round == 3 | round == 4 | round == . | treatment == . ",
    "egen strata = group(nahia_city_comb aboveMedianTotalBreadTea)",
    "tab strata, gen(stratum)",
    "gen round_temp = round - 1",
    "",
    "* Index without outlier ",
    "gen tax_index_noOut = tax_index",
    "qui sum tax_index",
    "replace tax_index_noOut = . if tax_index_noOut == r(max)",
    "",
    "*** A. Baseline results",
    "",
    "estimates clear",
    "tempfile prelim_results",
    "local n = 1",
    "foreach var in infTax_gov_others infTax_leader_others infTax_gov_you infTax_leader_you tax_index infTax_yesToAny{",
    "\t",
    "\tqui sum `var' if treatment == 0",
    "\tlocal mean_control = round(r(mean), 0.001)",
    "\t",
    "\t* Loop for variables with baseline information",
    "\tif regexm(\"`var'\", \"infTax\") == 1{",
    "\t\t",
    "\t\treghdfe `var' treatment `var'_base round_temp if t != 0, ///",
    "\t\t\tabsorb(strata) vce(cluster uniqueId)",
    "\t\t\t",
    "\t}",
    "\telse{ // Variables without baseline value",
    "\t\t",
    "\t\treghdfe `var' treatment round_temp if t != 0, ///",
    "\t\t\tabsorb(strata) vce(cluster uniqueId)",
    "\t\t",
    "\t}",
    "\t",
    "\testimates store coef_`n'",
    "\t",
    "\tif \"`n'\" == \"1\"{",
    "\t\tregsave using `prelim_results', replace ///",
    "\t\t\ttable(var_`n', parentheses(stderr) asterisk(10 5 1) format(%7.3f)) addvar(control_mean, `mean_control', `mean_control')",
    "\t}",
    "\telse{",
    "\t\tregsave using `prelim_results', append ///",
    "\t\t\ttable(var_`n', parentheses(stderr) asterisk(10 5 1) format(%7.3f)) addvar(control_mean, `mean_control', `mean_control')",
    "\t}",
    "\t",
    "\tlocal ++n",
    "}",
    "",
    "*** B. Long-term Effects"
  ],
