  "line_preview": [
    "//// RCT Survey: Graphics",
    "//// Lucas Reddinger <jlr@lucasreddinger.com>, David Levine, Gary Charness",
    "//// 2022 March 29; Updated 4 February 2025",
    "",
    "local this_file \"graphics\"",
    "",
    "local path_logs \"logs/\"",
    "local path_output \"output/\"",
    "local path_temp \"temp/\"",
    "",
    "local data_dta \"data\"",
    "",
    "capture mkdir `path_logs'",
    "capture mkdir `path_output'",
    "capture mkdir `path_temp'",
    "",
    "capture log close",
    "log using \"`path_logs'`this_file'.txt\", text replace",
    "",
    "**** End boilerplate",
    "",
    "",
    "**** Begin local configuration",
    "",
    "// set scheme plotplain",
    "set scheme s2mono",
    "",
    "** Define segment labels",
    "",
    "local label_b \"Black / African American\"",
    "local label_l \"Latinx / Hispanic\"",
    "local label_c \"Conservative\"",
    "local label_r \"Religious\"",
    "local label_p \"Parent\"",
    "local label_x \"Not in a segment\"",
    "local label_p_x \"Parents not in another segment\"",
    "",
    "** Define segment and control variable lists",
    "",
    "local segments \"b l c r p\"",
    "local segmentvars \"d_b d_l d_c d_r d_p\"",
    "",
    "**** End local configuration",
    "",
    "",
    "",
    "***************************",
    "***************************",
    "**** INTENT TO VACCINATE",
    "***************************",
    "***************************",
    "",
    "**** SAMPLE A",
    "",
    "use \"`path_temp'`data_dta'_sampleA.dta\", clear",
    "local N = _N",
    "",
    "local scale = 20",
    "gen vax_likely_b = `scale' * vax_likely - 7.5 if d_b==1",
    "gen vax_likely_l = `scale' * vax_likely - 4.5 if d_l==1",
    "gen vax_likely_c = `scale' * vax_likely - 1.5 if d_c==1",
    "gen vax_likely_r = `scale' * vax_likely + 1.5 if d_r==1",
    "gen vax_likely_p = `scale' * vax_likely + 4.5 if d_p==1",
    "gen vax_likely_x = `scale' * vax_likely + 7.5 if num_segs==0",
    "",
    "capture drop count",
    "bysort vax_likely_b : gen count = _N ",
    "count if vax_likely_b < . ",
    "gen vax_likely_b_pct = 100*(count / r(N))",
    "gen vax_likely_b_pct_str = string(vax_likely_b_pct, \"%4.0f\")",
    "capture drop count",
    "bysort vax_likely_l : gen count = _N ",
    "count if vax_likely_l < . ",
    "gen vax_likely_l_pct = 100*(count / r(N))",
    "gen vax_likely_l_pct_str = string(vax_likely_l_pct, \"%4.0f\")",
    "capture drop count",
    "bysort vax_likely_c : gen count = _N ",
    "count if vax_likely_c < . ",
    "gen vax_likely_c_pct = 100*(count / r(N))",
    "gen vax_likely_c_pct_str = string(vax_likely_c_pct, \"%4.0f\")"
  ],
