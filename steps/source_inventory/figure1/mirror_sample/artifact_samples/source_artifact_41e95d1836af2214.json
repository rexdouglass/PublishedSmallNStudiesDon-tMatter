  "line_preview": [
    "/***************************************************************************",
    "",
    "\tDESCRIPTION: \tThis do file generates several balance tables and",
    "\t\t\t\t\tsummary statistics. It performs the following tasks:",
    "\t\t\t\t\t- Creates a balance table with overall sample statistics",
    "\t",
    "\tINPUTS:\t\t\t- cleanedBaselineData.dta (cleaned baseline data)",
    "\t",
    "\tOUTPUTS:\t\t- Table A2",
    "",
    "***************************************************************************/",
    " ",
    "********************************************************************************",
    "* 0. PREAMBLE",
    "********************************************************************************",
    "",
    "clear",
    "clear matrix",
    "clear mata",
    "set more off",
    "estimates clear",
    "",
    "********************************************************************************",
    "* CREATING BALANCE TABLE",
    "********************************************************************************",
    "",
    "use \"${data}/cleanedBaselineData.dta\", clear",
    "",
    "* Creating matrix with the different elements ",
    "mat sumStats = J(19 ,5,.)",
    "",
    "local row = 1",
    "foreach var in totalBreadTea skippedMeals infTax_gov_others infTax_leader_others infTax_gov_you infTax_leader_you lifeSatisfaction happy married pashtun someEduc balkh herat kabul aboveMedianAge finDecisionMaker aboveMedianHHSize ableLeaveHouse{",
    "\t",
    "\tif regexm(\"`var'\", \"infTax\") == 1 local decimals = 0.001",
    "\telse local decimals = 0.01",
    "\t",
    "\t* Overall mean and SD",
    "\tqui sum `var'",
    "\tmat sumStats[`row', 1] = round(r(mean), `decimals')",
    "\tmat sumStats[`row', 2] = round(r(sd), `decimals')",
    "\t",
    "\t* Mean of treatment group",
    "\tqui sum `var' if treatment == 1",
    "\tmat sumStats[`row', 3] = round(r(mean), `decimals')",
    "\t",
    "\t* Mean of control group",
    "\tqui sum `var' if treatment == 0",
    "\tmat sumStats[`row', 4] = round(r(mean), `decimals')",
    "\t",
    "\t* p-value of difference",
    "\treghdfe `var' treatment, vce(robust)",
    "\ttest _b[treatment] == 0",
    "\tmat sumStats[`row', 5] = round(r(p), `decimals')",
    "\t",
    "\tlocal ++row",
    "\t",
    "}",
    "",
    "* Number of individuals",
    "qui count if treatment != .",
    "mat sumStats[`row', 1] = r(N)",
    "",
    "* Mean of treatment group",
    "qui count if treatment == 1",
    "mat sumStats[`row', 3] = r(N)",
    "",
    "* Mean of control group",
    "qui count if treatment == 0",
    "mat sumStats[`row', 4] = r(N)",
    "",
    "*** Generating table",
    "preserve",
    "clear",
    "svmat sumStats",
    "",
    "* Labels",
    "forvalues value = 1/5{",
    "\trename sumStats`value' sumStats`value'_aux",
    "\tgen sumStats`value' = strofreal(sumStats`value'_aux)"
  ],
