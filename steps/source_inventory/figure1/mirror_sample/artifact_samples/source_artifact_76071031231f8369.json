    "",
    "/*",
    "",
    "This file reproduces all Tables in Brierley, Kramon, and Ofosu (BKO) AJPS paper",
    "",
    "Created: February 20, 2019",
    "Code created and run on Stata/MP 15.1 for Mac",
    "",
    "This file produces Tables in the main body of the paper",
    "BKO_Debates_Replication_Appendix produces results in the Supplementary Information",
    "",
    "",
    "*/",
    "",
    "",
    "* Install required packages",
    "",
    "*To insall outreg2:",
    "ssc install outreg2",
    "",
    "*To install esttab:",
    "ssc install estout",
    "",
    "",
    "",
    "",
    "",
    "* set working directory to folder with the data",
    "",
    "cd \"\"",
    "",
    "",
    "*******************************************************************************",
    "** Open up data for main analysis.  Units are at the subject-candidate level",
    "",
    "use BKO_debates_main.dta, clear",
    "",
    " \t ",
    "*******************************************************************",
    "*******************************************************************",
    "*******************************************************************",
    "** Table 3",
    "",
    "set more off",
    "",
    "** This code creates matrices that contain the results",
    "* Tables in the paper are formatted by hand and the estimates are rounded",
    "",
    "** Panel A",
    "",
    "",
    "** Calculating means and SEs for each treatment group",
    "matrix define groupmeans = J(4,6,.)",
    "matrix colnames groupmeans = \"Control (1)\" \"Any Treatment (2)\" \"Personal background (3)\" ///",
    "\t\"Policy segment (4)\" \"Full debate (video) (5)\" \"Full debate (audio) (6)\"",
    "matrix rownames groupmeans = \"Mean\" \"SE\" \"ATE\" \"SE\"",
    "",
    "mean overall_ if T==0",
    "matrix x = r(table)",
    "matrix groupmeans[1,1] = x[1,1]",
    "matrix groupmeans[2,1] = x[2,1]",
    "",
    "mean overall_ if T==1",
    "matrix x = r(table)",
    "matrix groupmeans[1,2] = x[1,1]",
    "matrix groupmeans[2,2] = x[2,1]",
    "",
    "mean overall_ if A==1",
    "matrix x = r(table)",
    "matrix groupmeans[1,3] = x[1,1]",
    "matrix groupmeans[2,3] = x[2,1]",
    "",
    "mean overall_ if B==1",
    "matrix x = r(table)",
    "matrix groupmeans[1,4] = x[1,1]",
    "matrix groupmeans[2,4] = x[2,1]",
    "",
    "mean overall_ if C==1",
    "matrix x = r(table)",
    "matrix groupmeans[1,5] = x[1,1]"
  ],
