    "#' Tidy the results of the interaction analysis",
    "#'",
    "#' Lorem ipsum",
    "#'",
    "#' @param data the result of the calculate_interaction_stats function",
    "#'",
    "#' @return tidy table",
    "#' @export",
    "tidy_interaction_stats <- function(data) {",
    "  data %>%",
    "  dplyr::transmute(variable,",
    "                   BF = purrr::map_dbl(datt3,",
    "                                       ~ dplyr::slice(.x) %>%",
