  "line_preview": [
    "clear",
    "clear matrix",
    "set more off",
    "",
    "*************************************",
    "* Benford's law\t\t\t\t\t\t*",
    "*************************************",
    "* Benford, F. \"The Law of Anomalous Numbers.\" Proc. Amer. Phil. Soc. 78, 551-572, 1938.",
    "* Hill, T. P. \"The First Digit Phenomenon.\" Amer. Sci. 86, 358-363, 1998.",
    "",
    "**************************************",
    "cap program drop benford",
    "program define benford",
    "",
    "ta `3', matcell(empirics)",
    "forvalues i=1(1)9{",
    "local f`i' = round(empirics[`i',1]/r(N)*10000)/10000",
    "di \"`f`i''\"",
    "}",
    "loca b = r(N)",
    "matrix list empirics",
    "matrix theory=(log(1+1/1)\\log(1+1/2)\\log(1+1/3)\\log(1+1/4)\\log(1+1/5)\\log(1+1/6)\\log(1+1/7)\\log(1+1/8)\\log(1+1/9))/log(10)",
    "matrix normal=(1,1,1,1,1,1,1,1,1)*empirics",
    "local normal=normal[1,1]",
    "matrix empirics = empirics/`normal'-theory",
    "matrix error=empirics'*empirics",
    "matrix list empirics",
    "matrix list error",
    "local u = round(sqrt(error[1,1])*10^5)/10^5",
    "di \"`u'\"",
    "",
    "clear",
    "set obs 11",
    "gen digit = _n",
    "tostring digit, replace force",
    "replace digit = \"Observations\" if _n == 11",
    "replace digit = \"U\" if _n == 10",
    "gen a = .",
    "forvalues i=1(1)9{",
    "replace a = `f`i''  if _n == `i'",
    "}",
    "format %9.4g a",
    "replace a = `u' if _n == 10",
    "replace a = `b' if _n == 11",
    "ren a `1'",
    "save \"$temp/tmp_`2'\", replace",
    "end ",
    "**************************************",
    "",
    "",
    "* Collected data",
    "****************************",
    "use \"$final/final_stars_supp\", clear",
    "",
    "foreach var of varlist coefficient_num standard_deviation_num{",
    "generate dec_`var'=.",
    "forvalues i=-10(1)10{",
    "replace dec_`var'=abs(`var'*10^(`i')) if (abs(`var'*10^(`i'))>=1) & dec_`var'==.",
    "}",
    "replace dec_`var'=floor(dec_`var')",
    "}",
    "*",
    "save \"$temp/tmp1\", replace",
    "",
    "local tmin 1.65",
    "local tmax 6",
    "",
    "* Panel A: Coefficients",
    "",
    "* Full sample",
    "use \"$temp/tmp1\", clear",
    "benford \"coeff_full\" 1 \"dec_coefficient_num\"",
    "",
    "* Between 1.65 and 6",
    "use \"$temp/tmp1\", clear",
    "keep if t_stat_sm>=`tmin' & t_stat_sm<=`tmax'",
    "benford \"coeff_165_6\" 2 \"dec_coefficient_num\"",
    "",
    "* Outside 1.65 - 6",
    "use \"$temp/tmp1\", clear"
  ],
