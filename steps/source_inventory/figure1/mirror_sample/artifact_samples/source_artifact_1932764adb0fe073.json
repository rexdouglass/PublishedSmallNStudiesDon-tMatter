  "line_preview": [
    "/***************************************************************************",
    "",
    "\tDESCRIPTION: \tThis do file conducts heterogeneity analysis by ",
    "\t\t\t\t\trunning regressions with interaction terms for various ",
    "\t\t\t\t\tsubgroup characteristics and storing the results, and ",
    "\t\t\t\t\tgenerates plots displaying the baseline and ",
    "\t\t\t\t\theterogeneity estimates with 95% confidence intervals.",
    "\t",
    "\tINPUTS:\t\t\t- surveysDataset.dta",
    "\t",
    "\tOUTPUTS:\t\t- figure_a2_nutrition_index",
    "\t\t\t\t\t- figure_a2_econ_index",
    "\t\t\t\t\t- figure_a2_tax_index",
    "",
    "***************************************************************************/",
    " ",
    "********************************************************************************",
    "* 0. PREAMBLE",
    "********************************************************************************",
    "",
    "clear",
    "clear matrix",
    "clear mata",
    "set more off",
    "estimates clear",
    "",
    "********************************************************************************",
    "* 1. PREPARING DATA",
    "********************************************************************************",
    "use \"${data}/surveysDataset.dta\", clear",
    "",
    "drop if round == 3 | round == 4",
    "* Creating variables needed for analysis",
    "",
    "gen aboveMedTBT = aboveMedianTotalBreadTea",
    "",
    "gen round_temp = round - 1",
    "",
    "* Creating household head variable ",
    "gen is_hh_head_aux = hh_head == 1 if hh_head != . & round == 2",
    "egen is_hh_head = max(is_hh_head_aux), by(uniqueId)",
    "egen married_base = max(married), by(uniqueId)",
    "",
    "* Generating strata variable ",
    "egen strata = group(nahia_city_comb aboveMedianTotalBreadTea)",
    "",
    "********************************************************************************",
    "* 2. HETEROGENEITY ANALYSIS",
    "********************************************************************************",
    "",
    "mat hetAnalysis = J(33, 4, .)",
    "",
    "local row = 1",
    "local dep_var = 1",
    "foreach var in nutrition_index tax_index econ_index{",
    "\t",
    "\tlocal heter_var = 0",
    "\t",
    "\t* Baseline estimate ",
    "\treg `var' treatment i.nahia_city_comb aboveMedianTotalBreadTea round_temp if t != 0, vce(cluster uniqueId)",
    "\t",
    "\tmat hetAnalysis[`row', 1] = round(_b[treatment], 0.0001)",
    "\tmat hetAnalysis[`row', 2] = round(_se[treatment], 0.0001)",
    "\tmat hetAnalysis[`row', 3] = `dep_var'",
    "\tmat hetAnalysis[`row', 4] = `heter_var'",
    "\tlocal ++heter_var",
    "\tlocal ++row",
    "\t",
    "\tforeach het_var in aboveMedTBT totalBreadTea_base kabul ableLeaveHouse_base married_base pashtun someEduc aboveMedianAge finDecisionMaker_base aboveMedianHHSize{",
    "\t",
    "\t\ttempfile res_`het_var'",
    "\t\tlocal n = 1",
    "\t\t",
    "\t\tcap gen int_`het_var'_treat = `het_var' * treatment",
    "\t\t\t\t",
    "\t\t* Loop for variables with baseline information",
    "\t\tif inlist(\"`var'\", \"income\", \"employed\", \"totalBreadTea\", \"lifeSatisfaction\", \"happy\", \"medicinePurchase\", \"finDecisionMaker\", \"skippedMeals\") == 1{",
    "\t\t",
    "\t\t\treg `var' int_`het_var'_treat treatment `het_var' round_temp i.strata `var'_base if t != 0, vce(cluster uniqueId)",
    "\t\t\t"
  ],
