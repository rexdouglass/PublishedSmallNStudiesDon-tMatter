  "line_preview": [
    "clear",
    "set more off",
    "",
    "cap program drop summary_metadata_export",
    "program define summary_metadata_export",
    "",
    "local var \"`1'\"",
    "local title \"`2'\"",
    "",
    "* By test",
    "*********",
    "use \"$final/final_stars_supp\", clear",
    "",
    "local n = _N",
    "",
    "tab `var' if `var' == 1,  matcell(temp_mat)",
    "local freq_te = temp_mat[1,1]",
    "local share_te = round(`freq_te'/`n'*100)",
    "",
    "* By table",
    "**********",
    "use \"$final/final_stars_supp\", clear",
    "",
    "collapse `var',  by(journal_id issue article_page table_panel) fast",
    "replace `var' = 1 if `var' > 0",
    "",
    "local n = _N",
    "",
    "tab `var' if `var' == 1,  matcell(temp_mat)",
    "local freq_ta = temp_mat[1,1]",
    "local share_ta = round(`freq_ta'/`n'*100)",
    "",
    "* By article",
    "************",
    "use \"$final/final_stars_supp\", clear",
    "",
    "collapse `var',  by(journal_id issue article_page) fast",
    "replace `var' = 1 if `var' > 0",
    "",
    "local n = _N",
    "",
    "tab `var' if `var' == 1,  matcell(temp_mat)",
    "local freq_ar = temp_mat[1,1]",
    "local share_ar = round(`freq_ar'/`n'*100)",
    "",
    "",
    "",
    "* Write to file",
    "***************",
    "if \"`var'\" != \"D_all\" & \"`var'\" != \"D_main\"{",
    "file write myfile ///",
    "\"`title'\" _tab  %12.0fc (`freq_ar') _tab %12.0fc (`freq_ta') _tab %12.0fc (`freq_te') _newline ///",
    "\t\t\t_tab  \"[\" (`share_ar') \"]\" _tab \"[\" (`share_ta') \"]\" _tab \"[\" (`share_te') \"]\" _newline",
    "}",
    "if \"`var'\" == \"D_all\"{",
    "file write myfile ///",
    "\"`title'\" _tab  %12.0fc (`freq_ar') _tab %12.0fc (`freq_ta') _tab %12.0fc (`freq_te') _newline ///",
    "_newline",
    "}",
    "if \"`var'\" == \"D_main\"{",
    "file write myfile ///",
    "\"`title'\" _tab   \t\t_tab %12.0fc (`freq_ta') _tab %12.0fc (`freq_te') _newline ///",
    "\t\t  _tab  \t\t _tab \"[\" (`share_ta') \"]\" _tab \"[\" (`share_te') \"]\" _newline",
    "}",
    "end",
    "",
    "************************************************************************",
    "",
    "cap file close myfile",
    "file open myfile using \"$final/summary_metadata.xls\", write replace",
    "",
    "file write myfile _newline ///",
    "\"Sample\"\t_tab \"Articles\" _tab \"Tables\" _tab \"Tests\" _newline ///",
    "_newline",
    "",
    "",
    "summary_metadata_export \"D_all\" \"Full\"",
    "summary_metadata_export \"D_journal1\" \"American Economic Review\"",
    "summary_metadata_export \"D_journal2\" \"Quarterly Journal of Economics\"",
    "summary_metadata_export \"D_journal3\" \"Journal of Political Economy\""
