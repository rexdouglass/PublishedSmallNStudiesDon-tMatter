    "/***********************************",
    "CCTV DATA MAIN REGRESSIONS - PRIMARY OUTCOMES",
    "",
    "** Description: regress primary outcomes on ",
    "the treatment indicators and controls ",
    "",
    "** note: we use district FE instead of strata FE ",
    "due to the imbalanced distribution of treatment & control",
    "stations in some strata ",
    "***********************************/",
    "",
    "use \"$cc/cctv_full data.dta\", clear ",
    "",
    "include \"$s/Heterogeneity interactions.do\" ",
    "",
    "* merge with the personnel dataset to get the sizes of female/all staff ",
    "merge m:1 ps_code using \"$ps/police_station personnel data.dta\"",
    "drop _merge ",
    "",
    "* regression models ",
    "",
    "foreach x in women all wprop { \t",
    "\tgen bl_control = bavg_`x'",
    "",
    "\t* treatment + female officers + bl_control ",
    "\t\tqui reg eavg_`x' treatment e_female_staff bl_control strat_pca i.dist_id i.timeofday i.dayofweek eavg_`x'_fps eavg_`x'_pixels, robust cluster(ps_code) ",
    "\t\test sto `x'_tcplbluw ",
    "\t\tqui sum eavg_`x' if treatment == 0 ",
    "\t\testadd scalar ctrlmean = r(mean): `x'_tcplbluw",
    "\t\testadd local dist_urbanFE \"No\" ",
    "\t\testadd local distFE \"Yes\" ",
    "\t",
    "\t\tqui reg eavg_`x' regular_whd women_whd e_female_staff bl_control strat_pca i.dist_id i.timeofday i.dayofweek eavg_`x'_fps eavg_`x'_pixels, robust cluster(ps_code) ",
    "\t\test sto `x'_t1t2plbluw",
    "\t\tqui sum eavg_`x' if treatment == 0 ",
    "\t\testadd scalar ctrlmean = r(mean): `x'_t1t2plbluw ",
    "\t\tqui test _b[regular_whd] = _b[women_whd] ",
    "\t\testadd scalar p_val = r(p): `x'_t1t2plbluw",
    "\t\testadd local dist_urbanFE \"No\"",
    "\t\testadd local distFE \"Yes\" ",
    "\t***************************************************",
    "\tif \"`x'\" != \"wprop\" {",
    "\t\tdrop bl_control",
    "\t} ",
    "}",
    "",
    "",
    "label var bl_control \"Baseline control\"  ",
    "",
    "//================= EXPORT TABLES ==================// ",
    "",
    "",
    "// primary outcomes",
    "local \testtaboptions cells(b(star fmt(3)) se(par fmt(3))) varwidth(25) label star (* 0.1 ** 0.05 *** 0.01) nogap collabels(none)  ///",
    "        keep(treatment regular_whd women_whd bl_control) replace nofloat nonote ///",
    "\t\torder(treatment regular_whd women_whd bl_control) ///",
    "\t\tstats(N r2_a ctrlmean distFE p_val, labels(\"Obs.\" \"Adjusted R$^2$\"  \"Control mean\" \"District FE\" \"p-value: T1 = T2\") fmt(0 3 3 3)) ///",
    "\t\tmtitles(\"\\shortstack{\\# female\\\\visitors}\" \"\\shortstack{\\% female\\\\visitors}\" ///",
    "\t\t\t    \"\\shortstack{\\# female\\\\visitors}\" \"\\shortstack{\\% female\\\\visitors}\")",
    "\t\t\t\t",
    "esttab  women_tcplbluw wprop_tcplbluw ///",
    "\t\twomen_t1t2plbluw wprop_t1t2plbluw  ///",
    "\t\tusing \"$omt/Table2.tex\", `esttaboptions'",
    "",
