  "line_preview": [
    "clear",
    "set more off",
    "",
    "import excel using \"$source/additional_data_list_full.xls\", sheet(\"Article variables\") firstrow clear",
    "keep journal_id issue article_page data_availability codes_availability ras thanks field field_2 negative_result",
    "saveold \"$temp/supp_data_article\", replace",
    "",
    "import excel using \"$source/additional_data_list_full.xls\", sheet(\"Author variables\") firstrow clear",
    "keep author phd phd_date",
    "replace phd_date = \"Unknown\" if phd_date == \"Unkown\"",
    "",
    "destring phd_date, force replace",
    "",
    "saveold \"$temp/supp_data_authors\", replace",
    "",
    "import excel using \"$source/additional_data_list_full.xls\", sheet(\"Author x Article variables\") firstrow clear",
    "",
    "capture : drop N-R",
    "",
    "foreach var of varlist status*{",
    "replace `var' = \"Unknown\" if `var' == \"Unknwon\"",
    "replace `var' = \"Assistant Professor\" if regexm(lower(`var'),\"assistant\")==1 | `var' == \"Assitant\" | `var' == \"Assisant\" | `var' == \"AP\"",
    "replace `var' = \"Economist\" if regexm(lower(`var'),\"economist\")==1 | `var' == \"Senior Econ\"",
    "replace `var' = \"Postdoc\"  if regexm(lower(`var'),\"post doc\")==1 | `var' == \"Post-Doctorate\" | `var' == \"Juniorprofessor\"",
    "replace `var' = \"Other\"  if regexm(lower(`var'),\"research\")==1 | (`var' == \"Consultant\" | `var' ==  \"Director Economic\" | `var' ==  \"Vice President and Director\") | `var' == \"US Army as a Colonel\"",
    "replace `var' = \"Phd\"  if regexm(lower(`var'),\"phd\")==1 | regexm(lower(`var'),\"pdh\")==1 | regexm(lower(`var'),\"ph.d\")==1",
    "replace `var' = \"Associate Professor\"  if regexm(lower(`var'),\"associate\")==1 | (regexm(lower(`var'),\"lecturer\")==1 & regexm(lower(`var'),\"senior\")==1)",
    "replace `var' = \"Assistant Professor\" if regexm(lower(`var'),\"lecturer\")==1 | regexm(lower(`var'),\"reader\")==1",
    "replace `var' = \"Postdoc\"  if regexm(lower(`var'),\"fellow\")==1",
    "}",
    "tab status",
    "tab status_1",
    "tab status_2",
    "tab status_3",
    "",
    "",
    "foreach var of varlist editor*{",
    "replace `var' = \"Unknown\" if `var' == \"Unknwon\"",
    "replace `var' = \"Yes\" if lower(`var')==\"yes\"",
    "replace `var' = \"No\" if lower(`var')==\"no\"",
    "}",
    "tab editor",
    "tab editor_b",
    "",
    "saveold \"$temp/supp_data_authors_article\", replace"
