    "* Residuals from non-parametric estimations",
    "****************************************************************",
    "",
    "use \"$temp/export_from_r\", clear",
    "capture : drop xxx_1",
    "",
    "local k = 0",
    "",
    "foreach var of varlist yf_*{",
