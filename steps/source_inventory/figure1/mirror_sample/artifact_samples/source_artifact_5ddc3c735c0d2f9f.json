    "sort tmp1",
    "local b = round(tmp1[1]*100)/100",
    "local c = round(tmp[1]*1000)/1000",
    "di \"`a'\"",
    "di \"`b'\"",
    "di \"`c'\"",
    "drop tmp tmp1",
    "preserve",
    "\tclear",
    "\tset obs 1",
    "\tgen sample = \"`a'\"",
    "\tgen t_max_nonparam = `b'",
    "\tgen S_max_nonparam = `c'",
    "\tsave \"$temp/tmp`k'\", replace",
    "restore",
    "}",
    "*",
