    "************************************************",
    "*  - Policing in patriarchy: : Sandip Sukhtankar, Gabrielle Kruks-Wisner, and Akshay Mangla",
    "* Purpose: Master do-file. Runs a push-button replication of \"Policing in patriarchy: An experimental evaluation of reforms to improve police responsiveness to women in India\"",
    "* Last edited: 17 May 2022",
    "************************************************",
    "/* Instructions: .",
    "\t1. Set the path to this replication package in the areas marked \"SET DIRECTORY HERE\" (Line 19)",
    "\t2. Set the global \"supp;\" it takes 1 if you would like to replicate the supplement tables and 0 if not.",
    "\t3. Run this do-file ",
    "*/",
    "****************************************************************************",
    "",
    "clear all",
    "*** Step 1: setup",
    "\tset more off",
    "\tversion 16.1",
    "\t",
    "\t//Setting up globals",
    "\tglobal wd \"\" //SET DIRECTORY HERE",
    "\tcd \"$wd\"",
    "\t",
    "\tglobal supp = 1 //CHANGE TO 0 IF YOU DON'T WANT TO REPLICATE THE SUPPLEMENT TABLES",
    "\t",
    "\tglobal s \"Scripts\"",
    "\tglobal d \"Data\"",
    "\tglobal o \"Output\"",
    "\t",
    "\tglobal a \"${d}/Admin\"",
    "\tglobal cc \"${d}/CCTV\"",
    "\tglobal cs \"${d}/Citizen Survey\"",
    "\tglobal ps \"${d}/Police Survey\"",
    "\tglobal us \"${d}/User Survey\"",
    "\t",
    "\tglobal om \"${o}/Main_paper\"",
    "\tglobal os \"${o}/Supplement\"",
    "\t",
    "\tglobal omt \"${om}/Tables\"",
    "\tglobal omf \"${om}/Figures\"",
    "\tglobal ost \"${os}/Tables\"",
    "\t",
    "\tglobal sm \"${s}/Main_paper\"",
    "\tglobal ss \"${s}/Supplement\"",
    "",
    "",
    "\t* Step 2: Installing ssc commands necessary to run some chunks",
    "//\tcap ssc install esttab",
    "\t",
    "",
    "\t* Step 3: Running do-files",
    "",
    " // Main paper tables ",
    " forvalues x = 1/2{",
    " \tdo \"$sm/Table`x'.do\"",
    " }",
    " ",
    "  // Main paper figures ",
    " forvalues x = 1/4{",
    " \tdo \"$sm/Figure`x'.do\"",
    " }",
    " ",
    " if $supp == 1{",
    "   // Supplement tables ",
    "   do \"$ss/TableS2_panelA.do\"",
    "   do \"$ss/TableS2_panelB.do\"",
    "  forvalues x = 2/24{",
    " \tdo \"$ss/Tables`x'.do\"",
    " }",
    " }",
    " ",
    " "
