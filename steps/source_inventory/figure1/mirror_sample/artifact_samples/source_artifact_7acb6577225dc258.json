  "file_name": "graph_residuals_param.do",
  "file_type": "do",
  "line_preview": [
    "clear",
    "set more off",
    "",
    "use \"$temp/parametric_estimation\", clear",
    "",
    "*****************************",
    "*** Overall graphs syntax ***",
    "*****************************",
    "",
    "* Representation of selection functions",
    "***************************************",
    "capture : program drop graph_selfunction",
    "program define graph_selfunction",
    "local a =  regexr(\"`1'\",\"yf_\",\"\")",
    "local b =  substr(\"`1'\",-1,1)",
    "summ `1' if  x < 9",
    "local c = int(r(max)) + 1",
    "\tif \"`b'\" == \"r\"{",
    "\tlocal w = \"real\"",
    "\tlocal w1 = \"eal\"",
    "\t}",
    "\tif \"`b'\" == \"s\"{",
    "\tlocal w = \"student\"",
    "\tlocal w1 =\"tudent\"",
    "\t}",
    "\tif \"`b'\" == \"p\"{",
    "\tlocal w = \"psid\"",
    "\tlocal w1 = \"sid\"",
    "\t}",
    "\tif \"`b'\" == \"v\"{",
    "\tlocal w = \"vhlss\"",
    "\tlocal w1 = \"hlss\"",
    "\t}",
    "\tif \"`b'\" == \"q\"{",
    "\tlocal w = \"qog\"",
    "\tlocal w1 = \"og\"",
    "\t}",
    "\tif \"`b'\" == \"c\"{",
    "\tlocal w = \"cauchy\"",
    "\tlocal w1 =\"auchy\"",
    "\t}",
    "#delimit ;",
    "twoway scatter R_`a' x [w=`w'] if x < 9 & x>0.2 & R_`a'<`c' , mlwidth(vvthin) mlcolor(black) msize(tiny) msymbol(smcircle_hollow) || ///",
    "\t\tline `1' x if x<9 & x>0.2, lcolor(black) || ///",
    "\t\tline S_`a' x if x<9 & x>0.2, yaxis(2) lcolor(black) lpattern(dash) lwidth(medthick)",
    "\t\txlabel(1.96 \"1.96\" 9 \"9\") ",
    "scale(1.5)",
    "ytitle(\"Ratio observed/input density\", axis(1))",
    "ytitle(\"Cumulated residuals\", axis(2))   ",
    "ylabel(-0.06(0.03)0.06, axis(2) nogrid angle(0))  ",
    "ylabel(0(1)`c', axis(1) nogrid angle(0))  ",
    "xtitle(\"z-statistic\") ",
    "bgcolor(\"white\") graphregion(color(white))",
    "legend(pos(1) col(1) order(2 \"Best increasing fit\" 3 \"Cumulated residuals\") region(lstyle(none) lcolor(white)))",
    ";",
    "#delimit cr",
    "local c = regexr(\"`a'\",\"obs_\",\"\")",
    "graph export \"$figures\\selparam_`c'`w1'.eps\", replace",
    "graph export \"$figures\\selparam_`c'`w1'.png\", replace",
    "end",
    "/* Notes:",
    "Only one argument, designed to be  yf_ETC",
    "*/",
    "",
    "****************************",
    "****************************",
    "",
    "foreach var of varlist yf_obs_all_* yf_obs_*_r{",
    "graph_selfunction `var'",
    "}",
    "*",
    "",
    ""
  ],
