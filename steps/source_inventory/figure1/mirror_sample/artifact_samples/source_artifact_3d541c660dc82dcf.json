  "line_preview": [
    "clear",
    "clear matrix",
    "set more off",
    "",
    "*************************************",
    "* Regressions around thresholds\t\t*",
    "*************************************",
    "",
    "global export \"$final\\discontinuity.xls\"",
    "capture erase \"$final\\discontinuity.txt\"",
    "capture erase \"$export\"",
    "",
    "",
    "* Full sample",
    "*************",
    "use \"$final/final_stars_supp\", clear",
    "",
    "twoway__histogram_gen t_stat_sm if t_stat_sm<10.0 & t_stat_sm>0.0, start(0) width(0.00125) gen(real_y x)",
    "keep x real_y",
    "drop if x==.",
    "sort x",
    "",
    "generate x2=x^2",
    "",
    "foreach tau in 1.6448536 1.959964 2.5758293{",
    "foreach nu in 0.3 0.2 0.1 0.05{",
    "preserve",
    "keep if x<`tau'+`nu' & x>`tau'-`nu'",
    "generate sig=(x>`tau')",
    "reg real_y x x2 sig, robust",
    "su real_y",
    "local a = r(mean)",
    "outreg2 sig using \"$export\", dec(4) nocons nor2 noaster addstat(Density, `a', Window, `nu') ctitle(\"`tau'\") addtext(Sample, \"Full\")",
    "drop sig",
    "restore",
    "}",
    "}",
    "*",
    "",
    "* Eye-catcher sample",
    "********************",
    "use \"$final/final_stars_supp\", clear",
    "",
    "keep if D_eye == 1",
    "",
    "twoway__histogram_gen t_stat_sm if t_stat_sm<10.0 & t_stat_sm>0.0, start(0) width(0.00125) gen(real_y x)",
    "keep x real_y",
    "drop if x==.",
    "sort x",
    "",
    "generate x2=x^2",
    "",
    "foreach tau in 1.6448536 1.959964 2.5758293{",
    "foreach nu in 0.3 0.2 0.1 0.05{",
    "preserve",
    "keep if x<`tau'+`nu' & x>`tau'-`nu'",
    "generate sig=(x>`tau')",
    "reg real_y x x2 sig, robust",
    "su real_y",
    "local a = r(mean)",
    "outreg2 sig using \"$export\", dec(4) nocons nor2 noaster addstat(Density, `a', Window, `nu') ctitle(\"`tau'\") addtext(Sample, \"Eye-catchers\")",
    "drop sig",
    "restore",
    "}",
    "}",
