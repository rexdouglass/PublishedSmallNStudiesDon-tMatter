    "# 2. Main replication analysis",
    "## Study 2a and 2b",
    "",
    "```{r Study2a intention, echo = FALSE, message = FALSE, warning = FALSE, paged.print = FALSE}",
    "rscale <-  0.26",
    "vars1a <- c(\"trolley_3_rate\", \"trolley_2_rate\")",
    "",
    "studys1a_results <- ",
    "  bind_rows(",
    "    calculate_intention_stat(intention_a, vars = vars1a, ",
