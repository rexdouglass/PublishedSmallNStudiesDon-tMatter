    "get_pvalue_decorations <- function(pvalues) {",
    "   pvalue_decorations <- c(\"\", \"^{\\\\dagger}\", \"^{*}\", \"^{**}\", \"^{***}\")",
    "",
    "   pvalue_decorations[",
    "      as.integer(as.character(cut(",
    "         pvalues,",
    "         breaks = c(0, 0.001, 0.01, 0.05, 0.1, 1),",
    "         labels = 5:1,",
    "         include.lowest = TRUE",
    "      )))",
    "   ]",
    "}",
