  "line_preview": [
    "clear",
    "set more off",
    "",
    "*******************************",
    "* Creating the useful data set",
    "*******************************",
    "use \"$temp/stars_raw\", clear",
    "",
    "foreach var of varlist coefficient standard_deviation standard_deviation_2 standard_deviation_3 t_stat t_stat_2 t_stat_3 p_value{",
    "destring `var', force gen(`var'_num)",
    "}",
    "*",
    "",
    "* Identifying the precision of reported values",
    "**********************************************",
    "foreach var of varlist coefficient standard_deviation t_stat p_value{",
    "gen no_comma_`var' = subinstr(`var',\".\",\"\",1) if `var'_num  != .",
    "replace no_comma_`var' = subinstr(no_comma_`var',\"-\",\"\",1)",
    "count // Initialize counter within the loop",
    "while r(N) > 0 {",
    "replace no_comma_`var' = subinstr(no_comma_`var',\"0\",\"\",1) if substr(no_comma_`var', 1, 1) == \"0\"",
    "count if substr(no_comma_`var', 1, 1) == \"0\"",
    "}",
    "gen precision_`var' = length(no_comma_`var') if length(no_comma_`var') != 0",
    "drop no_comma_`var'",
    "}",
    "*",
    "",
    "gen precision = .",
    "",
    "* Store raw test statistics",
    "***************************",
    "\treplace precision = precision_t_stat if t_stat_num != .",
    "gen t_stat_A = t_stat_num if t_stat_num != .",
    "",
    "\treplace precision = 1 if coefficient_num == 0 & t_stat_A == .",
    "replace t_stat_A = 0 if coefficient_num == 0 & t_stat_A == .",
    "",
    "\treplace precision = min(precision_coefficient,precision_standard_deviation) if t_stat_A == .",
    "replace t_stat_A = coefficient_num / standard_deviation_num if t_stat_A == .",
    "",
    "\treplace precision = precision_p_value if t_stat_A == .",
    "replace t_stat_A = invnormal(p_value_num/2) if t_stat_A == .",
    "",
    "replace t_stat_A = abs(t_stat_A)",
    "",
    "* Round numbers",
    "***************",
    "set seed 51",
    "",
    "foreach var of varlist coefficient standard_deviation standard_deviation_2 standard_deviation_3 t_stat t_stat_2 t_stat_3 p_value{",
    "egen z = ends(`var'), punct(.) tail",
    "gen y = length(z)",
    "gen `var'_num_sm = `var'_num + (uniform() - 0.5)* 10^(-y)",
    "drop z y",
    "}",
    "*",
    "",
    "gen t_stat_B = t_stat_num_sm if t_stat_num_sm != .",
    "replace t_stat_B = 0 if coefficient_num_sm == 0 & t_stat_B == .",
    "replace t_stat_B = coefficient_num_sm / standard_deviation_num_sm if t_stat_B == .",
    "replace t_stat_B = invnormal(p_value_num_sm/2) if t_stat_B == .",
    "replace t_stat_B = . if t_stat_A == . & t_stat_B != . ",
    "replace t_stat_B = abs(t_stat_B)",
    "",
    "* Weights",
    "**********",
    "",
    "gen t = 1",
    "egen obs_by_article =  sum(t), by(journal_id issue article_page)",
    "egen obs_by_table = sum(t), by(journal_id issue article_page table_panel)",
    "drop t",
    "",
    "egen tag_table_article=tag(journal_id issue article_page table_panel table_panel)",
    "egen tab_by_article=sum(tag_table_article), by(journal_id issue article_page)",
    "drop tag_table_article",
    "",
    "generate weight_article=1/obs_by_article",
    "generate weight_table=1/obs_by_table * 1/tab_by_article",
    "generate weight_table_round=round(weight_table*10^8)"
  ],
