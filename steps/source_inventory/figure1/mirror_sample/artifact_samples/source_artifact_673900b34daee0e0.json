    "",
    "data <- data_orig[complete.cases(data_orig[indexer]),]",
    "x <- data[indexer]",
    "  \t\t\t\t\tif(length(revcols)>0){",
    "\t\t\t\t\t\tx[,revcols] <-  -1*x[,revcols]",
    "\t\t\t\t\t}",
    "",
    "\t\t\t\tfor(j in 1:ncol(x)){",
    "\t\t\t\t\tx[,j] <- (x[,j] - mean(x[,j]))/sd(x[,j])",
    "\t\t\t\t}",
    "",
    "\t\t\t\t\ti.vec <- as.matrix(rep(1,ncol(x)))",
    "\t\t\t\t\tSx <- cov(x)",
    "",
    "\t\t\t\t\tdata$index <- t(solve(t(i.vec)%*%solve(Sx)%*%i.vec)%*%t(i.vec)%*%solve(Sx)%*%t(x))",
    "data <- merge(data_orig,data[c(\"hhid\",\"index\")], by=\"hhid\",all.x=T)",
    "",
    "return( data )",
