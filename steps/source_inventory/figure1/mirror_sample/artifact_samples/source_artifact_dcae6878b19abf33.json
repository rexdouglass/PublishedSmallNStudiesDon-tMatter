  "line_preview": [
    "//// RCT Survey: Sample summary",
    "//// Lucas Reddinger <jlr@lucasreddinger.com>, David Levine, Gary Charness",
    "//// 2021 March 29; Updated 4 February 2025",
    "",
    "local this_file \"sample_summary\"",
    "",
    "local path_logs \"logs/\"",
    "local path_output \"output/\"",
    "local path_temp \"temp/\"",
    "",
    "local data_dta \"data\"",
    "",
    "capture mkdir `path_logs'",
    "capture mkdir `path_output'",
    "capture mkdir `path_temp'",
    "",
    "capture log close",
    "log using \"`path_logs'`this_file'.txt\", text replace",
    "",
    "**** End boilerplate",
    "",
    "",
    "",
    "******************************************************************************",
    "** LOAD ALL DATA",
    "******************************************************************************",
    "",
    "use \"`path_temp'`data_dta'.dta\", clear",
    "",
    "******************************************************************************",
    "** REMOVE DUPLICATE EXPERIMENTAL SURVEY RESPONDENTS",
    "** Keep one record for each respondent; prefer a finished survey record",
    "******************************************************************************",
    "",
    "gen finished_rev = finished==0 if finished<.",
    "sort subject_id finished_rev survey_clock",
    "quietly by subject_id (finished_rev survey_clock): gen dup_pid = cond(_N==1,0,_n)",
    "keep if dup_pid < 2",
    "sort subject_id",
    "drop finished_rev",
    "",
    "******************************************************************************",
    "** ENSURE PARTICIPANTS HAVE A UNIQUE IP",
    "******************************************************************************",
    "",
    "sort ipaddr_id",
    "quietly by ipaddr_id: gen ipaddr_seq = cond(_N==1,0,_n)",
    "",
    "gen dup_ipaddr = ipaddr_seq>0 & ipaddr_id<.",
    "",
    "tab excluded dup_ipaddr, mi",
    "",
    "gen dup_ip_or_excluded = dup_ipaddr==1 | excluded==1",
    "",
    "tab dup_ip_or_excluded, mi",
    "",
    "drop if dup_ip_or_excluded==1",
    "drop dup_ipaddr excluded dup_ip_or_excluded",
    "",
    "******************************************************************************",
    "** UNVACCINATED AND TOTAL PARTICIPANTS OVERALL AND BY SEGMENT",
    "******************************************************************************",
    "",
    "tab screen_novax, mi",
    "tab screen_novax if screen_b==1, mi",
    "tab screen_novax if screen_l==1, mi",
    "tab screen_novax if screen_c==1, mi",
    "tab screen_novax if screen_r==1, mi",
    "tab screen_novax if screen_v==1, mi",
    "",
    "******************************************************************************",
    "** INVITED PARTICIPANTS OVERALL AND BY SEGMENT",
    "** Excludes participants that should not have been invited due to duplicate IP",
    "******************************************************************************",
    "",
    "tab invited, mi",
    "tab invited if screen_b==1, mi",
    "tab invited if screen_l==1, mi",
    "tab invited if screen_c==1, mi",
    "tab invited if screen_r==1, mi"
  ],
