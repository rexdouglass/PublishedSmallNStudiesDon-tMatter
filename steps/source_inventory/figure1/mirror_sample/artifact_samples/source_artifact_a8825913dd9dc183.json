  "line_preview": [
    "//// RCT Survey: data setup",
    "//// Lucas Reddinger <jlr@lucasreddinger.com>, David Levine, Gary Charness",
    "//// 2021, 2025",
    "",
    "local this_file \"data_setup\"",
    "",
    "local path_logs \"logs/\"",
    "local path_temp \"temp/\"",
    "",
    "local data_public \"Reddinger_Levine_Charness_vaccination_rct\"",
    "",
    "capture mkdir `path_logs'",
    "capture mkdir `path_temp'",
    "",
    "capture log close",
    "log using \"`path_logs'`this_file'.txt\", text replace",
    "",
    "**** End boilerplate",
    "",
    "",
    "******************",
    "**** Sanity checks",
    "******************",
    "",
    "** Check missing values for subsegment determination",
    "",
    "tab d_b, mi",
    "tab d_l, mi",
    "tab d_c, mi",
    "tab d_r, mi",
    "tab d_p, mi",
    "",
    "** Check validity of survey variables.",
    "",
    "tab d_black d_b, mi",
    "tab d_latinx d_l, mi",
    "tab d_vote d_c, mi",
    "tab d_pols d_c if d_vote==3, mi",
    "tab d_relobs d_r, mi",
    "tab d_parent d_p, mi",
    "tab d_popdens d_smalltown_rural, mi",
    "",
    "** Check stability of Prolific characteristics against responses to our survey.",
    "** Remember that Prolific characteristics may be outdated.",
    "",
    "tab currentcountryofresidence d_reside, mi",
    "tab sex d_gender, mi",
    "tab age d_age, mi",
    "",
    "** Check validity of treatments",
    "",
    "tab t_b d_b, mi",
    "tab t_l d_l, mi",
    "tab t_nbnl d_b if d_l==1, mi",
    "tab t_nbnl d_l if d_b==1, mi",
    "tab t_spanish t_l, mi",
    "",
    "",
    "***********************",
    "**** Generate variables",
    "***********************",
    "",
    "gen d_male = d_gender == 1 if d_gender < ., after(t_spanish)",
    "",
    "** Generate subsegment categories",
    "// Encoded with meaning",
    "gen int subseg = (2^4)*d_b + (2^3)*d_l + (2^2)*d_c + (2^1)*d_r + (2^0)*d_p",
    "",
    "** The following requires Stata > 14, I think",
    "// egen subseg_b_str = base(subseg)",
    "// gen subseg_b_num = real(subseg_b_str) ",
    "// format subseg_b_num %08.0f",
    "",
    "** Generate message indicators",
    "gen m_popl_b = t_popl_b_pagesubmit < . if finished == 1",
    "gen m_popl_l = t_popl_l_pagesubmit < . if finished == 1",
    "",
    "gen m_comm_b = t_comm_b_pagesubmit < . if finished == 1",
    "gen m_comm_l = t_comm_l_pagesubmit < . if finished == 1",
    "gen m_comm_c = t_comm_c_pagesubmit < . if finished == 1"
  ],
