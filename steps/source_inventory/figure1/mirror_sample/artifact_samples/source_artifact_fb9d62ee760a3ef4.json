  "file_name": "5_2_estimation_param.do",
  "file_type": "do",
  "line_preview": [
    "clear",
    "set more off",
    "",
    "use \"$temp/export_param\", clear",
    "",
    "generate exp_x=exp(-x)",
    "generate exp_x2=exp(-x)^2",
    "",
    "* Create ratios",
    "***************",
    "foreach var of varlist obs_*{",
    "generate R_`var'_r = `var' / real",
    "generate R_`var'_v = `var' / vhlss",
    "generate R_`var'_p = `var' / psid",
    "generate R_`var'_q = `var' / qog",
    "generate R_`var'_s = `var' / student",
    "generate R_`var'_c = `var' / cauchy",
    "}",
    "*",
    "foreach var of varlist R_*{",
    "local a =  regexr(\"`var'\",\"R\",\"\")",
    "local b =  substr(\"`var'\",-1,1)",
    "\tif \"`b'\" == \"r\"{",
    "\tlocal w = \"real\"",
    "\t}",
    "\tif \"`b'\" == \"v\"{",
    "\tlocal w = \"vhlss\"",
    "\t}",
    "\tif \"`b'\" == \"q\"{",
    "\tlocal w = \"qog\"",
    "\t}",
    "\tif \"`b'\" == \"p\"{",
    "\tlocal w = \"psid\"",
    "\t}",
    "\tif \"`b'\" == \"c\"{",
    "\tlocal w = \"cauchy\"",
    "\t}",
    "\tif \"`b'\" == \"s\"{",
    "\tlocal w = \"student\"",
    "\t}",
    "quietly{",
    "reg `var' exp_x exp_x2 [weight=`w']",
    "predict yf`a'",
    "gen res`a' = `var' - yf`a'",
    "gen S`a' = 0",
    "sort x",
    "forvalues i= 1(1)1000{",
    "generate ind=(_n<=`i')*(_n>=0)",
    "egen sumtemp=sum(ind*`w'*res`a')",
    "replace S`a'=sumtemp if _n==`i'",
    "drop sumtemp ind",
    "}",
    "egen sumtemp=sum(`w'*`var')",
    "replace S`a'=S`a'/sumtemp[1000]",
    "drop sumtemp",
    "} // End of quietly",
    "} // End of foreach var of varlist R_*{",
    "*",
    "",
    "save \"$temp/parametric_estimation\", replace"
  ],
