  "line_preview": [
    "/***************************************************************************",
    "",
    "\tDESCRIPTION: \tThis do file runs regressions to prepare tables. It ",
    "\t\t\t\t\testimates treatment effects for nutrition and wellbeing ",
    "\t\t\t\t\toutcomes across two survey rounds. It also focuses on ",
    "\t\t\t\t\tother aspects, including types of food and economic ",
    "\t\t\t\t\toutcomes, with similar analysis steps.",
    "\t",
    "\tINPUTS:\t\t\t- surveysDataset.dta",
    "\t",
    "\tOUTPUTS:\t\t- table_2.tex",
    "\t\t\t\t\t- table_a3.tex",
    "",
    "***************************************************************************/",
    " ",
    "********************************************************************************",
    "* 0. PREAMBLE",
    "********************************************************************************",
    "",
    "clear",
    "clear matrix",
    "clear mata",
    "set more off",
    "estimates clear",
    "",
    "********************************************************************************",
    "* 1. PREPARING DATA",
    "********************************************************************************",
    "use \"${data}/surveysDataset.dta\", clear",
    "",
    "drop if round == 3 | round == 4",
    "",
    "replace round = round - 1",
    "gen inter_timeTreat = round * treatment",
    "",
    "* Generating strata variable ",
    "egen strata = group(nahia_city_comb aboveMedianTotalBreadTea)",
    "",
    "********************************************************************************",
    "* 1. TABLE 2 PAPER - NUTRITION + WELLBEING OUTCOMES",
    "********************************************************************************",
    "*** A. Estimation",
    "mat treatEffects = J(10, 4, .)",
    "tempfile prelim_results",
    "local n = 1",
    "foreach var in skippedMeals childSkippedMeals eatTwiceADay totalBreadTea nutrition_index econSituationImproved finSatisfied happy lifeSatisfaction econ_index{",
    "\t",
    "\tqui sum `var' if treatment == 0",
    "\tlocal mean_control = round(r(mean), 0.001)",
    "\t",
    "\t* Loop for variables with baseline information",
    "\tif inlist(\"`var'\", \"skippedMeals\", \"breadTea_lunch\", \"medicinePurchase\", \"happy\", \"lifeSat\", \"income\", \"employed\", \"finDecisionMaker\") == 1 | regexm(\"`var'\", \"infTax\") == 1{",
    "\t\t",
    "\t\treghdfe `var' inter_timeTreat round treatment `var'_base if t != 0, absorb(strata) vce(cluster uniqueId)",
    "\t\t",
    "\t}",
    "\telse{ // Variables without baseline value",
    "\t\t",
    "\t\treghdfe `var' inter_timeTreat round treatment if t != 0, ///",
    "\t\t\tabsorb(strata) vce(cluster uniqueId)",
    "\t\t",
    "\t}",
    "",
    "\tlincom inter_timeTreat + round + treatment",
    "\tlocal ratio = round(r(estimate) / _b[treatment], 0.01)",
    "\t",
    "\tif \"`n'\" == \"1\"{",
    "\t\tregsave using `prelim_results', replace ///",
    "\t\t\ttable(var_`n', parentheses(stderr) asterisk(10 5 1) format(%7.3f)) addvar(control_mean, `mean_control', `mean_control') addlabel(ratio, `ratio')",
    "\t}",
    "\telse{",
    "\t\tregsave using `prelim_results', append ///",
    "\t\t\ttable(var_`n', parentheses(stderr) asterisk(10 5 1) format(%7.3f)) addvar(control_mean, `mean_control', `mean_control') addlabel(ratio, `ratio')",
    "\t}",
    "\t",
    "\tmat treatEffects[`n', 3] = round(r(estimate), 0.00001)",
    "\tmat treatEffects[`n', 4] = round(r(se), 0.00001)",
    "",
    "\tlocal ++n",
    "\t"
  ],
