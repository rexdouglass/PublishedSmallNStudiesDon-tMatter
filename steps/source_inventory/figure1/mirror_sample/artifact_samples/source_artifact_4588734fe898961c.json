  "file_name": "graph_residuals.do",
  "file_type": "do",
  "line_preview": [
    "clear",
    "set more off",
    "",
    "use \"$temp/export_from_r\", clear",
    "",
    "*****************************",
    "*** Overall graphs syntax ***",
    "*****************************",
    "",
    "* Representation of selection functions",
    "***************************************",
    "capture : program drop graph_selfunction",
    "program define graph_selfunction",
    "local a =  regexr(\"`1'\",\"yf_\",\"\")",
    "local b =  substr(\"`1'\",-1,1)",
    "summ `1' if  x < 9",
    "local c = int(r(max)) + 1",
    "\tif \"`b'\" == \"l\"{",
    "\tlocal w = \"real\"",
    "\t}",
    "\tif \"`b'\" == \"t\"{",
    "\tlocal w = \"student\"",
    "\t}",
    "\tif \"`b'\" == \"y\"{",
    "\tlocal w = \"cauchy\"",
    "\t}",
    "\tif \"`b'\" == \"d\"{",
    "\tlocal w = \"psid\"",
    "\t}",
    "\tif \"`b'\" == \"s\"{",
    "\tlocal w = \"vhlss\"",
    "\t}",
    "\tif \"`b'\" == \"g\"{",
    "\tlocal w = \"qog\"",
    "\t}",
    "#delimit ;",
    "twoway scatter R_obs_`a' x [w=`w'] if x<9 & x>0.2 & R_obs_`a'<`c' , mlwidth(vvthin) mlcolor(black) msize(tiny) msymbol(smcircle_hollow) || ///",
    "\t   line `1' x if x<9 & x>0.2, lcolor(black) || ///",
    "\t   line S_`a' x if x<9 & x>0.2, yaxis(2) lcolor(black) lpattern(dash) lwidth(medthick)",
    "xlabel(1.96 \"1.96\" 9 \"9\") ",
    "scale(1.5)",
    "ytitle(\"Ratio observed/input density\", axis(1))  ",
    "ytitle(\"Cumulated residuals\", axis(2))  ",
    "ylabel(0(0.02)0.06, axis(2) nogrid angle(0))  ",
    "ylabel(0(1)`c', axis(1) nogrid angle(0))  ",
    "xtitle(\"z-statistic\") ",
    "bgcolor(\"white\") graphregion(color(white))  ",
    "legend(pos(1) col(1) order(2 \"Best increasing fit\" 3 \"Cumulated residuals\") region(lstyle(none) lcolor(white)))",
    ";",
    "#delimit cr",
    "graph export \"$figures\\sel_`a'.eps\", replace",
    "graph export \"$figures\\sel_`a'.png\", replace",
    "end",
    "/* Notes:",
    "Only one argument, designed to be  yf_ETC",
    "*/",
    "",
    "****************************",
    "****************************",
    "",
    "foreach var of varlist yf_all_* yf_*_real{",
    "graph_selfunction `var'",
    "}",
    "*",
    "",
    ""
  ],
