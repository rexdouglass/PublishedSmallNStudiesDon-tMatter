    "clear",
    "set more off",
    "",
    "use \"$final/final_stars_supp\", clear",
    "",
    "****************************",
    "*** Overall graph syntax ***",
    "****************************",
    "capture : program drop graph_stars",
    "",
    "program define graph_stars",
    "",
    "twoway histogram t_stat_sm if t_stat_sm<10.0 & t_stat_sm>=0 & `1'==1, bin(200) color($kolor) || ///",
    "kdensity t_stat_sm if t_stat_sm<10.0 & t_stat_sm>=0 & `1'==1, bwidth(0.2) color(black) ||, ///",
    "xlabel(0 \"0\" 1.96 \"1.96\" 10 \"10\") ///",
    "ylabel(0(0.1)0.4, angle(0) nogrid) ///",
    "ytitle(\"Density\") ///",
    "scale(1.5) ///",
    "xtitle(\"z-statistic\") ///",
    "bgcolor(\"white\") graphregion(color(white) margin(l-3 r+1)) plotregion(margin(zero)) ///",
    "legend(off)",
    "local a =  regexr(\"`1'\",\"D_\",\"\")",
    "graph export \"$figures\\sm_dist_`a'.eps\", replace",
    "graph export \"$figures\\sm_dist_`a'.png\", replace",
    "",
    "* Note: Only one argument.",
    "",
    "end",
    "****************************",
    "****************************",
    "",
    "foreach var of varlist D_datacodesavail D_datacodesavailNo D_dataother D_dataotherNo D_editorbefore D_editorbeforeNo D_eye D_eyeNo D_macro D_micro ///",
    "\tD_main D_mainNo D_model D_modelNo D_negNo D_negYes D_phdageOld D_phdageYoung D_ras D_rasNo D_single D_singleNo D_tenured3 D_tenured3No D_thanksHigh D_thanksLow{",
    "graph_stars \"`var'\"",
    "}",
    "*"
