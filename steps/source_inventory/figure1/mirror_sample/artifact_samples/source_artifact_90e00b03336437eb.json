  "line_preview": [
    "clear",
    "set more off",
    "",
    "* Transform the original dataset into something useful",
    "",
    "use \"$inputs/WDI_Data\", clear",
    "egen i = group(indicatorcode)",
    "local i = 1960",
    "foreach var of varlist v5-v58{",
    "ren `var' v`i'",
    "local i = `i' + 1",
    "}",
    "save tmp1, replace",
    "summ i",
    "local a = r(max)",
    "",
    "forvalues i = 1(1)`a'{",
    "use tmp1 if i == `i', clear",
    "reshape long v, i(countryname) j(year)",
    "keep countryname year v",
    "ren v v`i'",
    "\tif `i' == 1{",
    "\tsave tmp, replace",
    "\t}",
    "\tif `i' > 1{",
    "\tmerge 1:1 countryname year using tmp, nogenerate",
    "\tsave tmp, replace",
    "\t}",
    "}",
    "*",
    "compress",
    "order v*, sequential",
    "order countryname year",
    "save \"$temp/tmp_wdi\", replace",
    "",
    "erase tmp1.dta",
    "erase tmp.dta"
  ],
