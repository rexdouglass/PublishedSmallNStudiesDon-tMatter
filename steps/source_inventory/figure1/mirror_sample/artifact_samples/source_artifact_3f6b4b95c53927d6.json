            "fields": [
              {
                "multiple": true,
                "typeClass": "primitive",
                "typeName": "unitOfAnalysis",
                "value": [
                  "Multiple types: Students, Principal & teachers, school and classroom observation, household head"
                ]
              },
              {
                "multiple": true,
                "typeClass": "primitive",
                "typeName": "universe",
                "value": [
                  "Public schools in Liberia. Schools must: 1) have six or more classrooms, 2) have six or more teachers, 3) Have less than 65 students per classroom 4) be within 15 miles of the main road, and 5) Have 2G access (Only applies to Omega Academies, Rising Academies, and Bridge International Academies)."
                ]
              },
              {
                "multiple": false,
                "typeClass": "primitive",
                "typeName": "dataCollector",
                "value": "IPA field team in Liberia. Administrative data about different schools were provided by the principals or vice-principal from the sample schools."
              },
              {
                "multiple": false,
                "typeClass": "primitive",
                "typeName": "samplingProcedure",
                "value": "Based on criteria established by the evaluation team, MoE, and operators, 185  PSL-eligible schools were identified.  92 schools across 13 counties were randomly selected for treatment.  Each treated school will be administered by one of the eight private operators:  BRAC, Bridge, LIYONET, More than Me, Omega, Rising, Stella M, and Street Child. Since each operator has different criteria for the schools they are able to administer, each school submitted a set of criteria necessary for their schools. Based on these criteria, the universe of 185 experimental schools was split into 8 mutually exclusive groups corresponding to the 8 operators, with each operator’s group containing twice the number of schools that operator will manage. Within each of these groups, half of the schools were randomly chosen to be treated, with the rest serving as controls."
              },
              {
                "multiple": true,
                "typeClass": "primitive",
                "typeName": "collectionMode",
                "value": [
                  "In-person interviews and assessments"
                ]
              }
            ],
