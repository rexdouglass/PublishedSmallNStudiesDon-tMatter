  "line_preview": [
    "//// RCT Survey: Concordant topics",
    "//// Lucas Reddinger <jlr@lucasreddinger.com>, David Levine, Gary Charness",
    "//// 2022 March 29; Updated 4 February 2025",
    "",
    "local this_file \"concordant_topics\"",
    "",
    "local path_logs \"logs/\"",
    "local path_output \"output/\"",
    "local path_temp \"temp/\"",
    "",
    "local data_dta \"data\"",
    "",
    "capture mkdir `path_logs'",
    "capture mkdir `path_output'",
    "capture mkdir `path_temp'",
    "",
    "capture log close",
    "log using \"`path_logs'`this_file'.txt\", text replace",
    "",
    "**** End boilerplate",
    "",
    "",
    "**** Begin local configuration",
    "",
    "// set scheme plotplain",
    "set scheme s2mono",
    "",
    "** Define segment labels",
    "",
    "local label_b \"Black / African American\"",
    "local label_l \"Latinx / Hispanic\"",
    "local label_c \"Conservative\"",
    "local label_r \"Religious\"",
    "local label_p \"Parent\"",
    "local label_x \"Not in a segment\"",
    "local label_p_x \"Parents not in another segment\"",
    "",
    "** Define segment and control variable lists",
    "",
    "local segments \"b l c r p\"",
    "local segmentvars \"d_b d_l d_c d_r d_p\"",
    "",
    "**** End local configuration",
    "",
    "",
    "",
    "*********************",
    "*********************",
    "**** Concordant topic",
    "*********************",
    "*********************",
    "",
    "**** Load data for vax_likely",
    "use \"`path_temp'`data_dta'_sampleB.dta\", clear",
    "",
    "** OLS",
    "",
    "reg vax_likely ///",
    "\t\t\tconcord_commimpact concord_poptested concord_children ///",
    "\t\t\tconcord_elders concord_protection concord_gatherings ///",
    "\t\t\tconcord_availability concord_recommended i.subseg, r",
    "",
    "eststo e_ols_self, title(\"OLS\")",
    "",
    "test concord_commimpact concord_poptested concord_children ///",
    "\t\t\tconcord_elders concord_protection concord_gatherings ///",
    "\t\t\tconcord_availability concord_recommended",
    "estadd scalar test_all_topics_zero=r(p)",
    "",
    "capture drop subseg_count",
    "by subseg, sort: gen subseg_count = _n ==1",
    "replace subseg_count = sum(subseg_count)",
    "estadd scalar subsegments=subseg_count[_N]",
    "capture drop subseg_count",
    "",
    "** Ordered Logit",
    "",
    "ologit vax_likely ///",
    "\t\t\tconcord_commimpact concord_poptested concord_children ///",
    "\t\t\tconcord_elders concord_protection concord_gatherings ///"
  ],
