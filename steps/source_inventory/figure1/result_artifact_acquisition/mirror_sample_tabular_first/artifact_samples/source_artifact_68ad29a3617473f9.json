  "line_preview": [
    "# summary results table for corrections",
    "library(plyr)",
    "library(tidyverse)",
    "library(magrittr)",
    "library(emmeans)",
    "library(broom)",
    "library(ggstance)",
    "",
    "\"elusive-tab 1.csv\" %>% ",
    "  read_csv %>% ",
    "  mutate(",
    "    corr = corr  %>%",
    "      factor(",
    "        corr %>%",
    "          factor %>%",
    "          levels %>%",
    "          rev",
    "        )",
    "    ) %>% ",
    "  ddply(",
    "    .(study, item),",
    "    function(i){",
    "",
    "      lm1 <- lm(ans ~ ideol * corr,",
    "                data = i)",
    "      ",
    "      lm1 %>% ",
    "        emmeans(~corr | ideol, ",
    "                at = list(",
    "                  ideol = c(1, 4, 7)",
    "                )",
    "        ) %>% ",
    "        pairs(reverse = T) %>% ",
    "        tidy %>% ",
    "        select(",
    "          ideol:p.value",
    "        ) %>% ",
    "        rename(",
    "          \"ycat\" = ideol",
    "        ) %>% ",
    "        rbind(",
    "          lm1 %>%",
    "            emmeans(~ideol,",
    "                    at = list(",
    "                      ideol = c(1,  7)",
    "                    )",
    "            ) %>%",
    "            pairs %>%",
    "            tidy %>%",
    "            mutate(ycat = \"ideol\") %>% ",
    "            select(ycat, estimate:p.value)",
    "        )",
    "    }",
    "  ) %>% ",
    "  tbl_df %>% ",
    "  mutate(",
    "    ycat = ycat %>% ",
    "      mapvalues(",
    "        c(1, 4, 7, \"ideol\"),",
    "        c(\"Correction among liberals\",",
    "          \"Correction among moderates\",",
    "          \"Correction among conservatives\",",
    "          \"Absolute value of ideological effect\")",
    "        ) %>%",
    "      factor(",
    "        c(\"Correction among liberals\",",
    "          \"Correction among moderates\",",
    "          \"Correction among conservatives\",",
    "          \"Absolute value of ideological effect\")",
    "      ),",
    "    estimate = ycat %>%",
    "      str_detect(\"Absolute\") %>% ",
    "      ifelse(",
    "        estimate %>% ",
    "          abs,",
    "        estimate",
    "      ),",
    "    lab = estimate %>%",
    "      round(1) %>% ",
    "      str_replace(\"0.\", \".\") %>% "
  ],
