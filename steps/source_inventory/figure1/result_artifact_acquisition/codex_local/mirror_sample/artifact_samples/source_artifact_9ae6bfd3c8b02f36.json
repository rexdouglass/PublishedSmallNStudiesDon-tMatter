  "line_preview": [
    "# Clean-up",
    "rm(list=ls())",
    "",
    "# Get tidy",
    "library(tidyverse)",
    "",
    "# Import participant treatments (courses 47, 48, 49, 50, 51)",
    "participant_treatment_47 <- read.csv(\"course_47/participant_treatment.csv\",stringsAsFactors = FALSE)",
    "participant_treatment_48 <- read.csv(\"course_48/participant_treatment.csv\",stringsAsFactors = FALSE)",
    "participant_treatment_49 <- read.csv(\"course_49/participant_treatment.csv\",stringsAsFactors = FALSE)",
    "participant_treatment_50 <- read.csv(\"course_50/participant_treatment.csv\",stringsAsFactors = FALSE)",
    "participant_treatment_51 <- read.csv(\"course_51/participant_treatment.csv\",stringsAsFactors = FALSE)",
    "# Add course_ids",
    "participant_treatment_47$course_id <- 47",
    "participant_treatment_48$course_id <- 48",
    "participant_treatment_49$course_id <- 49",
    "participant_treatment_50$course_id <- 50",
    "participant_treatment_51$course_id <- 51",
    "# Rbind",
    "participant_treatment <- rbind(participant_treatment_47,",
    "                               participant_treatment_48,",
    "                               participant_treatment_49,",
    "                               participant_treatment_50,",
    "                               participant_treatment_51)",
    "# Rm",
    "rm(participant_treatment_47,participant_treatment_48,participant_treatment_49,participant_treatment_50,participant_treatment_51)",
    "",
    "# Clean condition names",
    "# > unique(participant_treatment$condition_name)",
    "# [1] \"Consent Logging Error\" \"No Prequestions\"       \"Prequestions\"          \"No Pre-Question\"       ",
    "# [5] \"Pre-Question\"          \"No Pre-Questions\"      \"Pre-Questions\"",
    "participant_treatment$condition_name <- recode(participant_treatment$condition_name, ",
    "                                               \"No Pre-Question\" = \"No Prequestions\", ",
    "                                               \"No Pre-Questions\" = \"No Prequestions\", ",
    "                                               \"Pre-Question\" = \"Prequestions\",",
    "                                               \"Pre-Questions\" = \"Prequestions\")",
    "",
    "# Clean assignment names",
    "# > unique(participant_treatment$assignment_name)",
    "# [1] \"Consent Logging Error\"             \"Application Assignment: Equal Sign\" \"Application: Hand Gesture\"          ",
    "# [4] \"Video 1\"                           \"Video 2\"                            \"Video 2 \"                           ",
    "# [7] \"Exam Prep Assignment 1\"             \"Exam Prep Assignment 2\" ",
    "participant_treatment$assignment_name <- recode(participant_treatment$assignment_name,",
    "                                                \"Application Assignment: Equal Sign\" = \"Equal Sign\",",
    "                                                \"Application: Hand Gesture\" = \"Hand Gesture\",",
    "                                                \"Video 1\" = \"Equal Sign\",",
    "                                                \"Video 2\" = \"Hand Gesture\",",
    "                                                \"Video 2 \" = \"Hand Gesture\",",
    "                                                \"Exam Prep Assignment 1\" = \"Equal Sign\",",
    "                                                \"Exam Prep Assignment 2\" = \"Hand Gesture\")",
    "",
    "# Check quantities",
    "# quantities <- participant_treatment %>% group_by(course_id,assignment_name,condition_name) %>% summarize(cnt_participants = length(unique(participant_id)))",
    "# view(quantities)",
    "# rm(quantities)",
    "",
    "# Problem: The participants who had the event logging error only show one assignment",
    "# (e.g., one row) in the participant_treatment table, which means that joins to this table ",
    "# may not return values.  Needed: Duplicate participants who had the logging error",
    "# so that the logging error is listed for both treatments.",
    "# Rough sketch:  For each participant...",
    "# 1. Determine whether they are in the consent-logging condition",
    "# 2. If so, confirm that they only appear once.",
    "# 3. If so, determine which exposure/assignment/treatment is missing",
    "# 4. Add rows to participant_treatment with missing exposure/assignment/treatment ids",
    "",
    "# For this plan, we need to know the correct IDs",
    "correct_ids <- participant_treatment %>% filter(condition_name != \"Consent Logging Error\") %>% group_by(course_id,exposure_id,assignment_id,treatment_id) %>% summarize()",
    "",
    "# And we need to know what ids were given to participants who had the consent ",
    "# logging error in each class.  Use the submissions table",
    "submissions_47 <- read.csv(\"course_47/submissions.csv\",stringsAsFactors = FALSE)",
    "submissions_48 <- read.csv(\"course_48/submissions.csv\",stringsAsFactors = FALSE)",
    "submissions_49 <- read.csv(\"course_49/submissions.csv\",stringsAsFactors = FALSE)",
    "submissions_50 <- read.csv(\"course_50/submissions.csv\",stringsAsFactors = FALSE)",
    "submissions_51 <- read.csv(\"course_51/submissions.csv\",stringsAsFactors = FALSE)",
    "# Add course_ids",
    "submissions_47$course_id <- 47",
    "submissions_48$course_id <- 48",
    "submissions_49$course_id <- 49"
  ],
