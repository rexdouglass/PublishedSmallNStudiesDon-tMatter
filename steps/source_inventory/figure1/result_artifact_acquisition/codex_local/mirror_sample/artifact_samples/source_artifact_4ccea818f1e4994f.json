  "file_type": "r",
  "line_preview": [
    "# Clean-up",
    "rm(list=ls())",
    "",
    "# Get tidy",
    "library(tidyverse)",
    "",
    "# Source DBDA2E Helpers",
    "source(\"Pilot Phase  Replication/DBDA2E-utilities.R\")",
    "",
    "# Read the relevant Terracotta exports",
    "# outcomes.csv is the outcome scores for each exposure, for each participant",
    "outcomes.1 <- read.csv('Pilot Phase  Pilot/course_38/outcomes.csv',stringsAsFactors = FALSE)",
    "outcomes.1$course_id <- 38",
    "outcomes.2 <- read.csv('Pilot Phase  Replication/outcomes.csv',stringsAsFactors = FALSE)",
    "outcomes <- rbind(outcomes.1,outcomes.2)",
    "rm(outcomes.1,outcomes.2)",
    "# participant_treatment.csv indicates, for each exposure, participants' condition assignments ",
    "participant_treatment.1 <- read.csv('Pilot Phase  Pilot/course_38/participant_treatment.csv',stringsAsFactors = FALSE)",
    "participant_treatment.1$course_id <- 38",
    "participant_treatment.1$consent_error <- FALSE",
    "participant_treatment.1 <- participant_treatment.1 %>% mutate(condition_name = if_else(condition_name==\"No PreQuestion\",\"No Prequestions\",\"Prequestions\"))",
    "participant_treatment.2 <- read.csv('Pilot Phase  Replication/participant_treatment.csv',stringsAsFactors = FALSE)",
    "participant_treatment <- rbind(participant_treatment.1,participant_treatment.2)",
    "rm(participant_treatment.1,participant_treatment.2)",
    "",
    "# ADDED POST-PREREGISTRATION: Select only the relevant outcomes",
    "outcomes <- outcomes %>% mutate(outcome_name = if_else(outcome_name == \"Gestures\",\"Gesture\",",
    "                                               if_else(outcome_name == \"Exam 3 Gesture\",\"Gesture\",",
    "                                               if_else(outcome_name == \"Exam 3 Equals Sign\",\"Equal Sign\",outcome_name)))) %>% filter(outcome_name %in% c(\"Equal Sign\",\"Gesture\"))",
    "# ADDED POST-REGISTRATION: Omit participants with consent error",
    "# outcomes <- outcomes %>% filter(participant_id %in% participant_treatment$participant_id[!participant_treatment$consent_error==TRUE])",
    "# ADDED POST-REGISTRATION: Omit participants missing outcome scores",
    "outcomes <- outcomes %>% filter(!participant_id %in% outcomes$participant_id[outcomes$outcome_score==\"N/A\"])",
    "",
    "# Create a single analysis table, datFrm",
    "# Simplify participant_treatment for easy merging",
    "participant_treatment <- participant_treatment %>% select(participant_id,exposure_id,condition_id,condition_name)",
    "# Join condition onto outcomes",
    "datFrm <- merge(outcomes,participant_treatment,by=c('participant_id','exposure_id'),all.x = TRUE)",
    "# Clean-up source tables",
    "# rm(outcomes,participant_treatment)",
    "# Simplify datFrm for only the participants, conditions, exposure, and outcome",
    "datFrm <- datFrm %>% select(participant_id,condition_name,exposure_id,points_possible,course_id,outcome_score)",
    "",
    "# ADDED POST-PREREGISTRATION: Additional formatting adjustments",
    "datFrm$outcome_score <- as.numeric(datFrm$outcome_score)",
    "datFrm <- na.omit(datFrm) # exclusion of missing outcome scores is preregistered",
    "datFrm$participant_id_factor <- as.numeric(as.factor(datFrm$participant_id))",
    "",
    "# Prepare data for JAGS",
    "sub <- datFrm$participant_id_factor",
    "x <- if_else(datFrm$condition_name == \"Prequestions\",1,0) # \"PreQuestion\"=1 & \"No PreQuestion\"=0",
    "w <- if_else(datFrm$exposure_id %in% c(748, 750, 752, 754, 761, 763),1,0) # exposure1=0 & exposure2=1",
    "y <- datFrm$outcome_score",
    "n <- datFrm$points_possible",
    "nRowsData <- nrow(datFrm)",
    "nSubs <- length(unique(sub))",
    "",
    "# Package for JAGS",
    "dataList = list(",
    "  y = y ,",
    "  n = n ,",
    "  x = x ,",
    "  w = w ,",
    "  sub = sub ,",
    "  nRowsData = nRowsData ,",
    "  nSubs = nSubs ",
    ")",
    "",
    "if (FALSE) { # If we're going to re-run the model...",
    "  ",
    "  modelString = \"",
    "  model {",
    "    ",
    "    for (i in 1:nRowsData) {",
    "      y[i] ~ dbin( ilogit(p[i]), n[i])",
    "      p[i] <- intercept[sub[i]] ",
    "              + (beta_x[sub[i]] * x[i]) # x is 0 and 1",
    "              + (beta_w[sub[i]] * w[i]) # w is 0 and 1",
    "    }"
  ],
