  "line_preview": [
    "suppressMessages({",
    "  library(DeclareDesign)",
    "  library(tidyverse)",
    "  library(kableExtra)",
    "  library(readxl)",
    "})",
    "",
    "set.seed(42)",
    "",
    "# Load estimates -----------------------------------------------",
    "",
    "meta_estimates_main_hypotheses <- read_rds(\"data/out/meta-estimates-main-hypotheses.RDS\")",
    "meta_estimates_sub_hypotheses <- read_rds(\"data/out/meta-estimates-sub-hypotheses.RDS\")",
    "meta_estimates_all_components <- read_rds(\"data/out/meta-estimates-all-components.RDS\")",
    "meta_estimates_secondary_hypotheses <- read_rds(\"data/out/meta-estimates-secondary-hypotheses.RDS\")",
    "meta_estimates_main_hypotheses_het <- read_rds(\"data/out/meta-estimates-main-hypotheses-het.RDS\")",
    "",
    "source(\"code/meta-analysis/0-variable-labels.R\")",
    "",
    "",
    "",
    "# Section C: Additional tables --------------------------------",
    "",
    "",
    "# Section C.1: Implementation details -------------------------",
    "",
    "# Table S1: Implementation Details by Site --------------------",
    "",
    "# Constructed manually by the study authors",
    "",
    "",
    "# Section C.2: Research design details ------------------------",
    "",
    "# Table S2: Study Site Experimental Designs -------------------",
    "",
    "# Constructed manually by the study authors",
    "",
    "",
    "# Table S3: Measurement differences across sites --------------",
    "",
    "# Constructed manually by the study authors",
    "",
    "",
    "",
    "# Section C.3: Meta-analysis results --------------------------",
    "",
    "# Table S4: Compliance results --------------------------------",
    "",
    "compliance_df1 <- ",
    "  meta_estimates_main_hypotheses %>%",
    "  filter(hypothesis == \"C\") %>% ",
    "  mutate(label = str_replace(label, \" idx.\", \"\"),",
    "         type = \"Overall\")",
    "",
    "compliance_df3 <- ",
    "  meta_estimates_sub_hypotheses %>%",
    "  filter(hypothesis == \"C\") %>%",
    "  mutate(label = str_replace(label_component, \" idx.\", \"\"),",
    "         type = \"Component\") %>%",
    "  arrange(desc(label_component))",
    "",
    "bind_rows(",
    "  compliance_df1,",
    "  compliance_df3",
    ") %>% ",
    "  mutate(ci = paste0(\"(\", formatC(conf.low, format = \"f\", digits = 3), \", \", ",
    "                     formatC(conf.high, format = \"f\", digits = 3), \")\"),",
    "         estimate = round(estimate, digits = 3),",
    "         std.error = round(std.error, digits = 3),",
    "         p.value = round(p.value, digits = 3)) %>% ",
    "  select(label, estimate, std.error, ci, p.value) %>% ",
    "  arrange(match(label, c(\"Compliance\"))) %>% ",
    "  kable(longtable = TRUE, escape = FALSE, digits = 3,  format = \"latex\", booktabs = TRUE, col.names = c(\"Measure\", \"Estimate\", \"S.E.\", \"Conf. Int.\", \"p-value\"),",
    "        caption = 'Compliance results', label = \"si-compliance-results\") %>% ",
    "  kable_styling(latex_options = \"repeat_header\") %>% ",
    "  as.character() %>% ",
    "  writeLines(con = \"article/tables/results/table-s4-metaanalysis-compliance.tex\")",
    "",
    "",
    "# Table S5: Primary hypotheses results ------------------------"
