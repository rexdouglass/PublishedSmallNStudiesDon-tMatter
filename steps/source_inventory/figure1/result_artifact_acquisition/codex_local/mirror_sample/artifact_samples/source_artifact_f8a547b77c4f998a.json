  "line_preview": [
    "#### Metaketa III: Brazil Paper",
    "####",
    "#### This uses elastic net regularization to predict treatment compliance.",
    "####",
    "#### We consider the following dependent variables:",
    "####",
    "#### complied - binary compliance variable coded using WhatsApp records",
    "#### num_months - count variable of months of messages from community, also coded using WhatsApp records",
    "####",
    "",
    "### Setup",
    "library(glmnet)",
    "library(caret)",
    "library(tidyverse)",
    "library(DataCombine)",
    "library(e1071)",
    "library(doParallel)",
    "library(collapse)",
    "library(dplyr)",
    "library(expss)",
    "library(readxl)",
    "library(gtools)",
    "library(ICC)",
    "library(ggplot2)",
    "",
    "set.seed(1)",
    "",
    "CROSSVAL <- 5",
    "REPS <- 5",
    "SHOCKSD <- 0.1",
    "KEEP.MINVARS <- 400",
    "",
    "## Get data",
    "load(file = \"baseline_forqual.Rdata\")",
    "load(file = \"trainersurvey_forqual.Rdata\")",
    "load(file = \"workshopstatus_forqual_rev.Rdata\")",
    "load(file = \"wells_forqual.Rdata\")",
    "load(file = \"blocks_forqual.Rdata\")",
    "load(file = \"sisar_forqual.Rdata\")",
    "sisar$community_ID <- sisar$locality",
    "precip <- read_excel(\"community_precip_stats.xlsx\", sheet = \"Sheet1\")",
    "",
    "## Calculate community-level averages for variables in baseline survey",
    "collapsed <- collap(test, ~community_ID)",
    "",
    "## Create variable in trainer survey for conflict (in either association or community)",
    "trainer_survey$conflict <- ifelse(trainer_survey$conflict_association==1 | trainer_survey$conflict_community==1, 1, 0)",
    "",
    "## Merge facilitator questionnaire and workshop variables",
    "baseline_trainer <- left_join(collapsed, trainer_survey, by=c(\"community_ID\"))",
    "base_train_work <- left_join(baseline_trainer, workshop, by=c(\"community_ID\"))",
    "base_train_work_precip <- left_join(base_train_work, precip, by=c(\"community_ID\"))",
    "base_train_work_precip_block <- left_join(base_train_work_precip, RA_block, by=c(\"community_ID\"))",
    "base_train_work_precip_block_sisar <- left_join(base_train_work_precip_block, sisar, by=c(\"community_ID\"))",
    "alldata <- left_join(base_train_work_precip_block_sisar, wells_agg, by=c(\"community_ID\"))",
    "",
    "## Recode number of water sources variable as NA when 0",
    "alldata$num_water_sources[alldata$num_water_sources==0] <- NA",
    "",
    "## Restrict sample to only treated communities",
    "treatedonly <- subset(alldata, complied==0 | complied==1)",
    "",
    "## Change precipitation variables to numeric",
    "treatedonly$avg_annual_p <- as.numeric(treatedonly$avg_annual_p)",
    "treatedonly$std_dev_p <- as.numeric(treatedonly$std_dev_p)",
    "treatedonly$n_std_dev_2012 <- as.numeric(treatedonly$n_std_dev_2012)",
    "treatedonly$n_std_dev_2018 <- as.numeric(treatedonly$n_std_dev_2018)",
    "treatedonly$avg_SPI3_jan_jun_2012 <- as.numeric(treatedonly$avg_SPI3_jan_jun_2012)",
    "treatedonly$avg_SPI3_jan_jun_2018 <- as.numeric(treatedonly$avg_SPI3_jan_jun_2018)",
    "",
    "## Change operador_communication variable to only weekly or not",
    "treatedonly$operador_communication_weekly <- NA",
    "treatedonly$operador_communication_weekly[treatedonly$operador_communication==\"weekly\"] <- 1",
    "treatedonly$operador_communication_weekly[treatedonly$operador_communication==\"rarely\"|treatedonly$operador_communication==\"monthly\"] <- 0",
    "",
    "## Identify variables with missing data",
    "colnames(treatedonly)[colSums(is.na(treatedonly)) > 0]",
    "",
    "## Create variable capturing quintiles of the water_noaccess_days_log variable",
    "treatedonly$water_noaccess_quintiles <- quantcut(treatedonly$water_noaccess_days_log, 5)"
  ],
