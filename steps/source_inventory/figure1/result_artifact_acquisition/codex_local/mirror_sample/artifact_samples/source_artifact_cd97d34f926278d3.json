    "##############################################################################",
    "###### Hares study AND online PRETEST Hare replication study preprocessing & analysis script #######################",
    "##############################################################################",
    "#### Nynke van der Laan ######################### UvA #########################",
    "##############################################################################",
    "# For a description of data preparation and cleaning, see datapreparatie_wervingsoverzicht.docx in the working directory",
    "rm(list=ls()) # First clear the workspace",
    "",
    "#### First do all calculations for the data of the original - Hare's study. ",
    "# Set working directory (root dir where the source datafiles are). ",
    "setwd(\"C:\\\\Surfdrive\\\\Onderzoek\\\\Studies\\\\ReplicationHare\\\\onlinepilot\\\\analysis\\\\\")",
    "",
    "# Load libraries",
    "#library(plyr) # for the mapvalues function",
    "#library(psy) # psy for the cronbach function",
    "#library(lme4) # for lmer function",
    "#library(lmerTest) # for p values",
    "#library(car) # car for the recode function",
    "",
    "## Handy commands:",
    "# Ctrl R = run selected lines",
    "# View(data) = bekijken dataset",
    "# str(data) = Get even more info about your datasetb",
    "",
    "#cLong to wide format data",
    "# wide_frame = data.frame(cast(choice_data, pp~trial_cat, value=c('choice_productcatHEvsLE_1vs0'), fun=mean))",
    "# EN weer terug in long format:",
    "# long_format = melt(wide_frame, id(c('pp')))",
    "",
    "###########",
    "#Read in the data. ",
    "data <- read.table(\"health_taste_choice_ratings_all_dieters_Harestudy.txt\", header = TRUE, sep = \"\\t\", dec=\".\")",
    "data$healthrating = as.numeric(as.character(data$healthrating))",
    "data$tasterating = as.numeric(as.character(data$tasterating))",
    "data$decision = as.numeric(as.character(data$decision))",
    "",
    "# Aggregate over products, remove missings. ",
    "data_agg = aggregate(cbind(healthrating, tasterating, decision) ~ stimulus, data = data, FUN=mean)",
    "",
    "# Get mean and sd of health and taste ratings of the stimuli",
    "mean(data_agg$healthrating)",
    "sd(data_agg$healthrating)",
    "mean(data_agg$tasterating)",
    "sd(data_agg$tasterating)",
    "",
    "# Calculate for how many subjects a health=3 and taste=2 ref product existed. ",
    "# Make indicator variable  ",
    "data$potential_refproduct3_3 = ifelse(((data$healthrating == 0) & (data$tasterating == 0)) , 1, 0)",
    "data$potential_refproduct4_3 = ifelse(((data$healthrating == 1) & (data$tasterating == 0)) , 1, 0)",
    "# Sum the number of refproducts over subjects",
    "data_temp = aggregate(cbind(potential_refproduct3_3, potential_refproduct4_3) ~ subject, data = data, FUN=sum)",
    "",
    "mean(data_temp$potential_refproduct3_3)",
    "mean(data_temp$potential_refproduct4_3)",
    "",
    "sum(data_temp$potential_refproduct3_3 < 1, na.rm=TRUE) ",
    "sum(data_temp$potential_refproduct4_3 < 1, na.rm=TRUE) ",
    "",
    "sum(((data_temp$potential_refproduct3_3 < 1) & (data_temp$potential_refproduct4_3 < 1)), na.rm=TRUE) ",
    "",
    "# Calculate how frequent the different categories existed. ",
    "# Make indicator variables  ",
    "data$likedhealthy = ifelse(((data$healthrating > 0) & (data$tasterating > 0)) , 1, 0)",
    "data$likedunhealthy = ifelse(((data$healthrating < 0) & (data$tasterating > 0)) , 1, 0)",
    "data$unlikedhealthy = ifelse(((data$healthrating > 0) & (data$tasterating < 0)) , 1, 0)",
    "data$unlikedunhealthy = ifelse(((data$healthrating < 0) & (data$tasterating < 0)) , 1, 0)",
    "data$SCrequired = ifelse((((data$healthrating > 0) & (data$tasterating < 0)) | ((data$healthrating < 0) & (data$tasterating > 0))) , 1, 0)",
    "data$tasteorhealth0 = ifelse(((data$healthrating == 0) | (data$tasterating == 0)) , 1, 0)",
    "",
    "data_temp = aggregate(cbind(tasteorhealth0, likedhealthy, likedunhealthy, unlikedhealthy, unlikedunhealthy, SCrequired) ~ subject, data = data, FUN=sum)",
    "",
    "mean(data_temp$likedhealthy)",
    "sd(data_temp$likedhealthy)",
    "mean(data_temp$likedunhealthy)",
    "sd(data_temp$likedunhealthy)",
    "mean(data_temp$unlikedhealthy)",
    "sd(data_temp$unlikedhealthy)",
    "mean(data_temp$unlikedunhealthy)",
    "sd(data_temp$unlikedunhealthy)",
    "mean(data_temp$SCrequired)"
  ],
