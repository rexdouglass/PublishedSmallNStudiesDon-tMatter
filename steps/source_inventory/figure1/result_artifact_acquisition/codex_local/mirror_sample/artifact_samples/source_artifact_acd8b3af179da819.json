    "12/21/2021",
    "1",
    "Article",
    "This markdown contains the analyses for the registered report: “Robustness of the rule learning effect in seven-month-old infants: A Close, multi-center replication of Marcus et al. (1999)”",
    "2",
    "Data preparation",
    "General first step: Load required packages",
    "library(psych)",
    "library(lme4)",
    "library(tidyverse)",
    "library(pbapply)",
    "library(broom)",
    "library(Matrix)",
    "library(grid)",
    "library(rprime)",
    "library(wrapr)",
    "library(brms)",
    "library(ggpirate)",
    "library(readxl)",
    "library(rstatix)",
    "library(rstan)",
    "options(width = 150)",
    "knitr::opts_chunk$set(message = FALSE, warning = FALSE)",
    "3",
    "Load data files for each lab",
    "3.1",
    "Amsterdam",
    "Step 1: Load button press data",
    "filelist <- list.files(path = \"Amsterdam\", pattern = \"*.txt\", full.names = TRUE)",
    "datalist <- lapply(filelist, function(x)read.delim(x, header=F, sep = \"\\t\", blank.lines.skip=TRUE) %>%",
    "slice(3:n()) %>%",
    "janitor::row_to_names(1) %>%",
    "mutate(filename = x,",
    "participant = str_remove(filename, \".txt\") %>%",
    "str_remove(., \"Amsterdam/\") %>%",
    "paste(., \"A\", sep = \"_\"),",
    "lab = \"Amsterdam\"))",
    "Step 2: Merge with background information",
    "backgroundAmsterdam <- read_excel(\"Amsterdam/Background_Amsterdam.xlsx\") %>%",
    "mutate(participant = paste(Subject, \"A\", sep = \"_\")) %>%",
    "select(`Age (days)`, Gender, participant, Condition, L1:L5H)",
    "datafrAmsterdam <- as.tibble(do.call(\"rbind\", datalist)) %>%",
    "left_join(., backgroundAmsterdam, by = c(\"participant\")) %>%",
    "mutate(familiarization_pattern = str_replace_all(Condition, \"_\\\\d\", \"\")) %>%",
    "group_by(participant) %>%",
    "mutate(trial_number = cumsum(event == \" START_SOUND \")) %>%",
    "ungroup()",
    "Step 3: Create columns information about trial type and consistency, and then calculate looking times",
    "ltAmsterdam <- datafrAmsterdam %>%",
    "mutate(trial_type = ifelse(as.factor(datafrAmsterdam$sound) ==",
    "\" Sound Files\\\\test_stream_ba_po_ba.wav \",",
    "\"Ba_Po_Ba\",",
    "ifelse(as.factor(datafrAmsterdam$sound) ==",
    "\" Sound Files\\\\test_stream_ba_po_po.wav \",",
    "\"Ba_Po_Po\",",
    "ifelse(as.factor(datafrAmsterdam$sound) ==",
    "\" Sound Files\\\\test_stream_ko_ga_ga.wav \",",
    "\"Ko_Ga_Ga\",",
    "ifelse(as.factor(datafrAmsterdam$sound) ==",
    "\" Sound Files\\\\test_stream_ko_ga_ko.wav \",",
    "\"Ko_Ga_Ko\", NA)))),",
    "condition = ifelse(((trial_type == \"Ba_Po_Po\" | trial_type == \"Ko_Ga_Ga\" ) &",
    "familiarization_pattern == \"XYY\") |",
    "((trial_type == \"Ba_Po_Ba\" | trial_type == \"Ko_Ga_Ko\" ) &",
    "familiarization_pattern == \"XYX\"), \"Consistent\",",
    "ifelse(((trial_type == \"Ba_Po_Po\" | trial_type == \"Ko_Ga_Ga\" ) &",
    "familiarization_pattern == \"XYX\") |",
    "((trial_type == \"Ba_Po_Ba\" | trial_type == \"Ko_Ga_Ko\" ) &",
    "familiarization_pattern == \"XYY\"), \"Inconsistent\", NA))) %>%",
    "group_by(trial_number, participant, trial_type, lab, familiarization_pattern, condition) %>%",
    "mutate(diff = lead(as.numeric(time)) - as.numeric(time)) %>%",
    "filter(event == \" START_SOUND \" | event == \" PRESS \") %>%",
    "group_by(trial_number, participant, trial_type, lab, familiarization_pattern, condition) %>%",
    "summarise(looking_time = sum(diff)) %>% #check for trials that last 15 ms straight"
  ],
