    "# Read the relevant Terracotta exports",
    "# participant_treatment.csv indicates, for each exposure, participants' condition assignments ",
    "participant_treatment.1 <- read.csv('Pilot Phase  Pilot/course_38/participant_treatment.csv',stringsAsFactors = FALSE)",
    "participant_treatment.1$course_id <- 38",
    "participant_treatment.1$consent_error <- FALSE",
    "participant_treatment.1 <- participant_treatment.1 %>% mutate(condition_name = if_else(condition_name==\"No PreQuestion\",\"No Prequestions\",\"Prequestions\"))",
    "participant_treatment.2 <- read.csv('Pilot Phase  Replication/participant_treatment.csv',stringsAsFactors = FALSE)",
    "participant_treatment <- rbind(participant_treatment.1,participant_treatment.2)",
    "rm(participant_treatment.1,participant_treatment.2)",
    "condition_dtl <- participant_treatment %>% select(treatment_id,condition_name,exposure_id) %>% distinct()",
    "",
    "# Import question IDs and conditions",
    "items.1 <- read.csv(\"Pilot Phase  Pilot/course_38/items.csv\",stringsAsFactors = FALSE)",
    "items.1$course_id <- 38",
    "items.2 <- read.csv(\"Pilot Phase  Replication/items.csv\",stringsAsFactors = FALSE)",
    "items <- rbind(items.1,items.2)",
    "rm(items.1,items.2)",
    "items <- merge(items,condition_dtl,by=\"treatment_id\",all.x = TRUE) %>% select(question_id = item_id,condition_name) ",
    "",
    "# Import events",
    "events_df.1 <- read.csv(\"Pilot Phase  Pilot/events.csv\",stringsAsFactors = FALSE)",
    "events_df.2 <- read.csv(\"Pilot Phase  Replication/events.csv\",stringsAsFactors = FALSE)",
    "events_df <- rbind(events_df.1,events_df.2)",
    "rm(events_df.1,events_df.2)",
    "",
    "# Merge conditions onto events",
    "events_df <- merge(events_df,items,by=\"question_id\",all.x=TRUE)",
    "",
    "# Fix target_id to only be the YouTube ID",
    "events_df <- events_df %>% mutate(target_id = if_else(grepl(\"AunjHffklZI\",target_id,fixed=TRUE),\"AunjHffklZI\",",
    "                                                      if_else(grepl(\"n7LC_AZEVz4\",target_id,fixed=TRUE),\"n7LC_AZEVz4\",\"\")))",
    "",
    "# Turn generated_id into submission_id",
    "events_df <- events_df %>% mutate(submission_id = str_split(generated_id,\"/\",simplify=TRUE)[,14])",
    "",
    "# Turn timestamp in to posix",
    "events_df <- events_df %>% mutate(timestamp = as.POSIXct(strptime(timestamp, \"%Y-%m-%dT%H:%M:%S\")))",
    "# time_dist <- events_df %>% mutate(hour = format(timestamp, format = \"%H\")) %>% na.omit()",
    "# hist(as.numeric(time_dist$hour))",
    "",
    "# Timing of events ",
    "# Make an \"event_secs\" column translated from YouTube playtimes",
    "events_df <- events_df %>% mutate(event_secs = if_else(target_time==\"P0D\",0,",
    "                                                       if_else(grepl('M',target_time,fixed=TRUE),",
    "                                                               as.numeric(str_split(target_time,\"PT|M|S\",simplify = TRUE)[,2])*60 + as.numeric(str_split(target_time,\"PT|M|S\",simplify = TRUE)[,3]),",
    "                                                               if_else(grepl('PT',target_time,fixed=TRUE),",
    "                                                                               as.numeric(str_split(target_time,\"PT|M|S\",simplify = TRUE)[,2]),",
    "                                                                               0))))",
    "# Make a percent column, percent of total playtime",
    "events_df <- events_df %>% mutate(event_pct = if_else(target_id=='AunjHffklZI',event_secs/252,",
    "                                                      if_else(target_id=='n7LC_AZEVz4',event_secs/240,0)))",
