    "# This script is simply for the placebo awareness items (Appendix B)",
    "",
    "##### Load Packages (RUN) ####",
    "library(rio)",
    "library(data.table)",
    "library(tidyverse)",
    "library(officer)",
    "library(flextable)",
    "library(lme4)",
    "library(jtools)",
    "library(ggpubr)",
    "library(ggeffects)",
    "",
    "#### Import the data ####",
    "France <- import(\"France_Clean.xlsx\") ",
    "France = filter(France, ID != \"269673804484654\" & ID != \"269691675940032\" &ID != \"269691676822544\")",
    "Germany <- import(\"Germany_Clean.xlsx\") ",
    "",
    "France$Politics = as.character(France$Politics)",
    "Germany$Politics = as.character(Germany$Politics)",
    "",
    "France <- France %>% mutate(country = \"France\")",
    "Germany <- Germany %>% mutate(country = \"Germany\")",
    "",
    "France$Politics = as.character(France$Politics)",
    "Germany$Politics = as.character(Germany$Politics)",
    "",
    "France <- France[, c(\"ID\", \"WA_or_IG\", \"Control_Treatment\", \"Politics\", \"gender\", \"age\", \"Education\",",
