    "# Define a function (for later use) for turning event list from json into a data frame",
    "process_events <- function (elist,course_id) {",
    "  elist_df <- data.frame()",
    "  for (i in 1:nrow(elist)){",
    "    type <- as.character(elist$data[[i]]$type)",
    "    if (type==\"MediaEvent\") {",
    "      participant_id <- as.integer(elist$data[[i]]$actor$extensions$terracotta_participant_id)",
    "      # type <- as.character(elist$data[[i]]$type)",
    "      item_id <- as.numeric(tail(strsplit(elist$data[[i]]$object$extensions$terracotta_question_id,'/')[[1]],1))",
    "      action <- as.character(elist$data[[i]]$action)",
    "      timestamp <- as.character(elist$data[[i]]$eventTime)",
    "      generated_id <- \"\"",
    "      target_id <- as.character(elist$data[[i]]$target$id)",
    "      target_time <- elist$data[[i]]$target$currentTime",
    "      event_row <- cbind.data.frame(course_id,participant_id,type,item_id,action,timestamp,generated_id,target_id,target_time)",
    "      elist_df <- rbind(elist_df,event_row)",
    "    } else {",
    "      participant_id <- as.integer(elist$data[[i]]$actor$extensions$terracotta_participant_id)",
    "      # type <- as.character(elist$data[[i]]$type)",
    "      item_id <- \"\"",
    "      action <- as.character(elist$data[[i]]$action)",
    "      timestamp <- as.character(elist$data[[i]]$eventTime)",
    "      generated_id <- elist$data[[i]]$generated$id"
  ],
