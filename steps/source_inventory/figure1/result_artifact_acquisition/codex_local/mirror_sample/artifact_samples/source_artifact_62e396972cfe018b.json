  "line_preview": [
    "## ----------------------------------",
    "## BUILD_ANALYSIS_SET.R",
    "## ----------------------------------",
    "# This script uses \"processed_data.Rdata\" (created",
    "# by the PREPROCESSING.R script) to create a",
    "# single analysis set, \"analysis_set.Rdata\"",
    "# This set includes the outcome scores for each",
    "# participant, and all relevant moderator values",
    "# in a single data frame: datFrm.",
    "",
    "# Clean-up",
    "rm(list=ls())",
    "",
    "# Required Libraries",
    "require(tidyverse)",
    "",
    "# Load the data",
    "# load(url(\"https://osf.io/sznm4/download\"))",
    "load(file = \"processed_data.Rdata\")",
    "",
    "## ",
    "## CREATE THE CORE OUTCOME DATA FRAME: datFrm",
    "##",
    "",
    "datFrm <- outcomes %>% filter(outcome_name %in% c(\"Exposure 1\",\"Exposure 2\"))",
    "# Simplify datFrm for only the participants, conditions, exposure, and outcome",
    "datFrm <- datFrm %>% select(participant_id,condition_name,outcome_name,points_possible,course_id,outcome_score)",
    "# Remove NAs",
    "datFrm <- na.omit(datFrm) # exclusion of missing outcome scores is preregistered",
    "# Pivot-wider so that every row is a participant",
    "datFrm <- distinct(datFrm)",
    "datFrm <- datFrm %>% pivot_wider(id_cols = c(participant_id,course_id),",
    "                                 names_from = c(condition_name,outcome_name), ",
    "                                 values_from = c(outcome_score,points_possible)) ",
    "datFrm <- datFrm %>% mutate(outcome_prequestions = if_else(is.na(`outcome_score_Pre-Questions_Exposure 1`),`outcome_score_Pre-Questions_Exposure 2`,`outcome_score_Pre-Questions_Exposure 1`),",
    "                            outcome_control = if_else(is.na(`outcome_score_Control_Exposure 1`),`outcome_score_Control_Exposure 2`,`outcome_score_Control_Exposure 1`),",
    "                            points_possible_prequestions = if_else(is.na(`points_possible_Pre-Questions_Exposure 1`),`points_possible_Pre-Questions_Exposure 2`,`points_possible_Pre-Questions_Exposure 1`),",
    "                            points_possible_control = if_else(is.na(`points_possible_Control_Exposure 1`),`points_possible_Control_Exposure 2`,`points_possible_Control_Exposure 1`),",
    "                            exposure_order = if_else(is.na(`outcome_score_Control_Exposure 1`),\"prequestions_then_control\",\"control_then_prequestion\"))",
    "datFrm <- datFrm %>% select(participant_id,course_id,exposure_order,outcome_prequestions,points_possible_prequestions,outcome_control,points_possible_control)",
    "datFrm <- na.omit(datFrm) # exclusion of missing outcome scores is preregistered",
    "# Add factor-ish versions of the participant and course ids",
    "datFrm$participant_id_factor <- as.numeric(as.factor(datFrm$participant_id))",
    "datFrm$course_id_factor <- as.numeric(as.factor(datFrm$course_id))",
    "",
    "# Lookup key for course_id and course_id_factor",
    "datFrm %>% group_by(course_id,course_id_factor) %>% summarize(n = length(unique(participant_id)))",
    "",
    "##",
    "## GET THE THREE ADDITIONAL MODERATOR VALUES FROM OUTCOMES",
    "##",
    "# We'll do this one-by-one to avoid any funny business: LEVEL, PRETEST, IN_MAJOR",
    "",
    "# LEVEL",
    "level <- outcomes %>% filter(outcome_name == \"Level\") %>% select(participant_id,level=outcome_score,points_possible) %>% distinct()",
    "level <- level %>% mutate(level = if_else(points_possible<12,level+12,level)) %>% select(participant_id,level) %>% distinct()",
    "datFrm <- merge(datFrm,level,by=\"participant_id\",all.x = TRUE) ",
    "rm(level)",
    "",
    "# PRETEST",
    "pretest <- outcomes %>% filter(outcome_name == \"Pretest\") %>% select(participant_id,pretest=outcome_score,points_possible) %>% distinct()",
    "pretest <- pretest %>% select(participant_id,pretest) %>% distinct() # No additional processing necessary",
    "datFrm <- merge(datFrm,pretest,by=\"participant_id\",all.x = TRUE)",
    "rm(pretest)",
    "",
    "# IN_MAJOR",
    "in_major <- outcomes %>% filter(outcome_name == \"In Program of Study\") %>% select(participant_id,in_major=outcome_score,points_possible) %>% distinct()",
    "in_major <- in_major %>% mutate(in_major = replace_na(in_major, 0)) %>% select(participant_id,in_major) %>% distinct()",
    "datFrm <- merge(datFrm,in_major,by=\"participant_id\",all.x = TRUE)",
    "rm(in_major)",
    "",
    "##",
    "## GET EVENTS DATA AND APPEND ONTO datFrm",
    "##",
    "",
    "# Turn event timestamp into POSIX",
    "events <- events %>% mutate(timestamp = as.POSIXct(timestamp))",
    "",
    "# Need empty data frames for...",
    "# ... View duration"
